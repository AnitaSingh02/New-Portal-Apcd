@model IEnumerable<APCD.Web.Models.EmpanelmentApplication>
@using System.Security.Claims
@{
    ViewData["Title"] = "Task Queue";
    var userRole = User.FindFirst(ClaimTypes.Role)?.Value;
    var screenTitle = userRole switch {
        "DEALING_HAND" => "Document Verification Queue",
        "FIELD_VERIFIER" => "Field Inspection Queue",
        "OFFICER" => "Tech Evaluation Queue",
        "COMMITTEE" => "Committee Final Review",
        "ADMIN" or "SUPER_ADMIN" => "Full Administrative Access",
        _ => "Application Review"
    };
}

<div class="container py-5 mt-4">
    <div class="row align-items-center mb-5 animate-fade-in">
        <div class="col-md-8">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-2">
                    <li class="breadcrumb-item"><a href="#" class="text-decoration-none">NPC Admin</a></li>
                    <li class="breadcrumb-item active">Dashboard</li>
                </ol>
            </nav>
            <h2 class="fw-bold text-gov-blue">@screenTitle</h2>
            <p class="text-muted">You have <strong>@Model.Count()</strong> pending applications in your queue.</p>
        </div>
        <div class="col-md-4 text-md-end">
            <div class="d-inline-flex bg-white p-2 rounded-pill shadow-sm border">
                <div class="px-3 border-end">
                    <small class="d-block text-muted text-uppercase extra-small fw-bold">System Status</small>
                    <span class="text-success fw-bold small"><i class="bi bi-circle-fill me-1 extra-small"></i> Active</span>
                </div>
                <div class="px-3">
                    <small class="d-block text-muted text-uppercase extra-small fw-bold">Server Time</small>
                    <span class="fw-bold small">@DateTime.Now.ToString("HH:mm")</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Stats for Admin -->
    @if (userRole == "ADMIN" || userRole == "SUPER_ADMIN")
    {
        <div class="row g-4 mb-5 animate-fade-in">
            <div class="col-md-3">
                <div class="card border-0 shadow-sm rounded-4 p-4 h-100 bg-white">
                    <div class="d-flex align-items-center gap-3">
                        <div class="bg-primary bg-opacity-10 p-3 rounded-4"><i class="bi bi-file-earmark-text text-primary fs-4"></i></div>
                        <div>
                            <h3 class="fw-bold mb-0">@Model.Count()</h3>
                            <small class="text-muted">Total Active</small>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-0 shadow-sm rounded-4 p-4 h-100 bg-white">
                    <div class="d-flex align-items-center gap-3">
                        <div class="bg-warning bg-opacity-10 p-3 rounded-4"><i class="bi bi-clock-history text-warning fs-4"></i></div>
                        <div>
                            <h3 class="fw-bold mb-0">@Model.Count(a => a.Status == "Submitted")</h3>
                            <small class="text-muted">New Claims</small>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-0 shadow-sm rounded-4 p-4 h-100 bg-white">
                    <div class="d-flex align-items-center gap-3">
                        <div class="bg-success bg-opacity-10 p-3 rounded-4"><i class="bi bi-check-circle text-success fs-4"></i></div>
                        <div>
                            <h3 class="fw-bold mb-0">@Model.Count(a => a.Status == "Empaneled")</h3>
                            <small class="text-muted">Empaneled</small>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-0 shadow-sm rounded-4 p-4 h-100 bg-white">
                    <div class="d-flex align-items-center gap-3">
                        <div class="bg-info bg-opacity-10 p-3 rounded-4"><i class="bi bi-credit-card text-info fs-4"></i></div>
                        <div>
                            <h3 class="fw-bold mb-0">₹@((Model.Sum(a => a.Payment?.Amount ?? 0m) / 1000).ToString("N0"))K</h3>
                            <small class="text-muted">Fees Collected</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }

    <div class="card shadow-sm border-0 rounded-4 overflow-hidden animate-fade-in">
        <div class="card-header bg-white py-4 px-4 border-bottom d-flex align-items-center justify-content-between">
            <h5 class="mb-0 fw-bold text-gov-blue">Applications List</h5>
            <form asp-action="Index" method="get" class="input-group w-auto">
                <span class="input-group-text bg-light border-0"><i class="bi bi-search"></i></span>
                <input type="text" name="search" value="@ViewBag.Search" class="form-control form-control-sm bg-light border-0" placeholder="Search ID or Company..." style="width: 250px;" />
                <button type="submit" class="btn btn-sm btn-gov-primary px-3 rounded-end shadow-sm">Search</button>
            </form>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0 align-middle">
                    <thead class="bg-light">
                        <tr class="extra-small text-uppercase text-muted fw-bold">
                            <th class="ps-4 py-3">Reference ID</th>
                            <th>Company Details</th>
                            <th>Applied On</th>
                            <th>Status Badge</th>
                            <th>Internal Track</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="border-top-0">
                        @foreach (var app in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="fw-bold text-gov-blue mb-0">#@app.Id.ToString("0000")</div>
                                    <small class="text-muted extra-small">OEM Profile Attached</small>
                                </td>
                                <td>
                                    <div class="fw-bold mb-0 text-truncate" style="max-width: 200px;">@(app.User.CompanyProfile?.CompanyName ?? app.User.FullName)</div>
                                    <small class="text-muted">@app.User.Email</small>
                                </td>
                                <td>
                                    <div class="small fw-600">@(app.SubmittedAt?.ToShortDateString() ?? app.CreatedAt.ToShortDateString())</div>
                                    <small class="text-muted extra-small">@(app.SubmittedAt?.ToShortTimeString() ?? "")</small>
                                </td>
                                <td>
                                    @switch (app.Status) {
                                        case "Submitted":
                                            <span class="badge bg-info-subtle text-info border border-info-subtle rounded-pill px-3">New Submission</span>
                                            break;
                                        case "DocumentApproved":
                                            <span class="badge bg-primary-subtle text-primary border border-primary-subtle rounded-pill px-3">Docs Verified</span>
                                            break;
                                        case "ProvisionalGranted":
                                            <span class="badge bg-warning-subtle text-warning-emphasis border border-warning-subtle rounded-pill px-3">Provisional Grant</span>
                                            break;
                                        case "FieldVerified":
                                            <span class="badge bg-indigo-subtle text-indigo border border-indigo-subtle rounded-pill px-3">Site Inspected</span>
                                            break;
                                        case "Empaneled":
                                            <span class="badge bg-success-subtle text-success border border-success-subtle rounded-pill px-3">Active (Empaneled)</span>
                                            break;
                                        default:
                                            <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle rounded-pill px-3">@app.Status</span>
                                            break;
                                    }
                                </td>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="progress w-100" style="height: 6px;">
                                            @{
                                                var progress = app.Status switch {
                                                    "Submitted" => 20,
                                                    "DocumentApproved" => 40,
                                                    "ProvisionalGranted" => 60,
                                                    "FieldVerified" => 80,
                                                    "Empaneled" => 100,
                                                    _ => 10
                                                };
                                            }
                                            <div class="progress-bar bg-gov-blue" role="progressbar" style="width: @progress%"></div>
                                        </div>
                                        <small class="text-muted extra-small fw-bold">@progress%</small>
                                    </div>
                                </td>
                                <td class="text-end pe-4">
                                    <a asp-action="Details" asp-route-id="@app.Id" class="btn btn-sm btn-gov-primary px-3 rounded-pill fw-bold">Review Application</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            @if (!Model.Any())
            {
                <div class="text-center py-5">
                    <div class="mb-3 text-muted"><i class="bi bi-inbox fs-1"></i></div>
                    <h5 class="text-muted">Your Task Queue is Clear</h5>
                    <p class="small text-muted">No applications currently require your action.</p>
                </div>
            }
        </div>
    </div>
</div>

<style>
    body { background-color: #f8f9fa; }
    .extra-small { font-size: 0.7rem; }
    .fw-600 { font-weight: 600; }
    .text-indigo { color: #6610f2; }
    .bg-indigo-subtle { background-color: #e2d9f3; }
</style>
