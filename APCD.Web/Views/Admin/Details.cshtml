@model APCD.Web.Models.EmpanelmentApplication
@using System.Security.Claims
@{
    ViewData["Title"] = "Review Application";
    var userRole = User.FindFirst(ClaimTypes.Role)?.Value;

    // Define Role-Specific Next Steps
    var nextStatus = Model.Status switch {
        "Submitted" when (userRole == "DEALING_HAND" || userRole == "ADMIN" || userRole == "SUPER_ADMIN") => "DocumentApproved",
        "DocumentApproved" when (userRole == "OFFICER" || userRole == "ADMIN" || userRole == "SUPER_ADMIN") => "ProvisionalGranted",
        "ProvisionalGranted" when (userRole == "FIELD_VERIFIER" || userRole == "ADMIN" || userRole == "SUPER_ADMIN") => "FieldVerified",
        "FieldVerified" when (userRole == "OFFICER" || userRole == "ADMIN" || userRole == "SUPER_ADMIN") => "CommitteeReviewPending",
        "CommitteeReviewPending" when (userRole == "COMMITTEE" || userRole == "ADMIN" || userRole == "SUPER_ADMIN") => "Empaneled",
        _ => (userRole == "ADMIN" || userRole == "SUPER_ADMIN") ? "Manual-Review-Required" : null
    };

    var actionLabel = nextStatus switch {
        "DocumentApproved" => "Verify Documents",
        "ProvisionalGranted" => "Grant Provisional Status",
        "FieldVerified" => "Submit Field Report",
        "CommitteeReviewPending" => "Schedule Final Committee Review",
        "Empaneled" => "Issue Final Empanelment",
        _ => "Administrative Feedback Only"
    };
}

<div class="container py-5 mt-4">
    <div class="row g-4 animate-fade-in">
        <!-- Main Application Content -->
        <div class="col-lg-8">
            <div class="card shadow-sm border-0 rounded-4 overflow-hidden mb-4">
                <div class="card-header bg-white py-4 px-4 border-bottom d-flex align-items-center justify-content-between">
                    <div>
                        <h4 class="fw-bold text-gov-blue mb-1">Empanelment Application #@Model.Id.ToString("0000")</h4>
                        <p class="text-muted small mb-0">Submitted by <strong>@Model.User.FullName</strong> on @Model.SubmittedAt?.ToLongDateString()</p>
                    </div>
                    <span class="badge bg-gov-blue text-white rounded-pill px-4 py-2">@Model.Status</span>
                </div>
                <div class="card-body p-4">
                    <!-- OEM Profile Section -->
                    <div class="row mb-5">
                        <div class="col-12 mb-3">
                            <h6 class="fw-bold text-muted text-uppercase extra-small letter-spacing">OEM Profile</h6>
                            <hr class="mt-2 mb-4" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <small class="text-muted d-block">Company Name</small>
                            <span class="fw-bold text-gov-blue fs-5">@(Model.User.CompanyProfile?.CompanyName ?? "No Profile Found")</span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <small class="text-muted d-block">GST / PAN</small>
                            <span class="fw-bold text-gov-blue">@(Model.User.CompanyProfile?.GSTNumber ?? "-") / @(Model.User.CompanyProfile?.PANNumber ?? "-")</span>
                        </div>
                        <div class="col-md-12 mb-3">
                            <small class="text-muted d-block">Factory Address</small>
                            <span class="text-secondary small">@(Model.User.CompanyProfile?.FactoryAddress ?? "-")</span>
                        </div>
                    </div>

                    <!-- Payment Section -->
                    @if (Model.Payment != null)
                    {
                        <div class="row mb-5">
                            <div class="col-12 mb-3">
                                <h6 class="fw-bold text-muted text-uppercase extra-small letter-spacing">Payment Acknowledgment</h6>
                                <hr class="mt-2 mb-4" />
                            </div>
                            <div class="col-md-6">
                                <div class="p-3 bg-light rounded-4 border-start border-4 border-success">
                                    <small class="text-muted d-block">Total Fees Paid</small>
                                    <h4 class="fw-bold text-success mb-0">₹@Model.Payment.Amount.ToString("N0")</h4>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="p-3 bg-light rounded-4">
                                    <small class="text-muted d-block">UTR / Transaction ID</small>
                                    <span class="fw-bold text-gov-blue fs-5">@Model.Payment.UTRNumber</span>
                                </div>
                            </div>
                        </div>
                    }

                    <!-- Documents Section -->
                    <div class="row mb-5">
                        <div class="col-12 mb-3">
                            <h6 class="fw-bold text-muted text-uppercase extra-small letter-spacing">Uploaded Documents</h6>
                            <hr class="mt-2 mb-4" />
                        </div>
                        <div class="col-12">
                            <div class="table-responsive rounded-4 border">
                                <table class="table table-hover mb-0 align-middle">
                                    <thead class="bg-light extra-small fw-bold text-muted">
                                        <tr>
                                            <th class="ps-4 py-3">Document Type</th>
                                            <th>File Name</th>
                                            <th class="text-end pe-4">Action</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var doc in Model.Documents)
                                        {
                                            <tr>
                                                <td class="ps-4 fw-bold small text-gov-blue">@doc.DocumentType</td>
                                                <td class="text-muted small">@doc.FileName</td>
                                                <td class="text-end pe-4"><a href="@doc.FilePath" target="_blank" class="btn btn-sm btn-outline-gov-blue"><i class="bi bi-eye me-1"></i>View</a></td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>

                    <!-- Installatons Section -->
                    <div class="row">
                        <div class="col-12 mb-3">
                            <h6 class="fw-bold text-muted text-uppercase extra-small letter-spacing">Installation Experience</h6>
                            <hr class="mt-2 mb-4" />
                        </div>
                        <div class="col-12">
                            <div class="row g-3">
                                @foreach (var inst in Model.Installations)
                                {
                                    <div class="col-md-6">
                                        <div class="p-3 bg-light rounded-4 border-0">
                                            <div class="fw-bold text-gov-blue">@inst.ClientName</div>
                                            <div class="small text-muted mb-2"><i class="bi bi-geo-alt me-1"></i>@inst.Location</div>
                                            <div class="extra-small text-muted fw-bold text-uppercase">Completed @@ @inst.InstallationDate.ToShortDateString()</div>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Sidebar Actions & Timeline -->
        <div class="col-lg-4">
            <!-- Workflow Action Center -->
            @if (nextStatus != null)
            {
                <div class="card shadow-sm border-0 border-top border-4 border-gov-gold rounded-4 overflow-hidden mb-4 animate-slide-up">
                    <div class="card-body p-4">
                        <h5 class="fw-bold text-gov-blue mb-4">Workflow Action Center</h5>
                        
                        <form asp-action="ProcessAction" method="post">
                            <input type="hidden" name="id" value="@Model.Id" />
                            
                            <div class="mb-4">
                                <label class="form-label small fw-bold text-muted text-uppercase">Internal Remark / Decision Note</label>
                                <textarea name="comment" class="form-control bg-light" rows="4" placeholder="Mention document validity, missing info, or verification notes..." required></textarea>
                            </div>

                            <div class="d-grid gap-2">
                                @if (nextStatus != "Manual-Review-Required")
                                {
                                    <input type="hidden" name="nextStatus" value="@nextStatus" />
                                    <button type="submit" class="btn btn-gov-primary btn-lg py-3 rounded-pill fw-bold shadow-sm">
                                        @actionLabel <i class="bi bi-shield-check ms-1"></i>
                                    </button>
                                }
                                else
                                {
                                    <input type="hidden" name="nextStatus" value="@Model.Status" />
                                    <button type="submit" class="btn btn-outline-gov-blue btn-lg py-3 rounded-pill fw-bold">
                                        Add Internal Remark <i class="bi bi-chat-left-text ms-1"></i>
                                    </button>
                                }
                                
                                <div class="d-flex gap-2 mt-2">
                                    <button type="submit" name="nextStatus" value="Rejected" class="btn btn-outline-danger btn-sm rounded-pill flex-grow-1">Reject Application</button>
                                    <button type="submit" name="nextStatus" value="Request-Info" class="btn btn-outline-warning btn-sm rounded-pill flex-grow-1">Request Info</button>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            }

            <!-- Status Tracking Timeline -->
            <div class="card shadow-sm border-0 rounded-4 overflow-hidden mb-4">
                <div class="card-header bg-white py-3 px-4 border-bottom">
                    <h6 class="mb-0 fw-bold text-gov-blue">Internal History & Remarks</h6>
                </div>
                <div class="card-body p-4">
                    <div class="timeline">
                        <!-- Initial Submission -->
                        <div class="timeline-item pb-4">
                            <div class="timeline-marker bg-success"></div>
                            <div class="timeline-content ps-3">
                                <h6 class="mb-0 fw-bold small text-gov-blue">Application Submitted</h6>
                                <p class="extra-small text-muted mb-0">@Model.SubmittedAt?.ToLongDateString()</p>
                            </div>
                        </div>

                        <!-- Current Remarks Log -->
                        @foreach (var remark in Model.Remarks.OrderByDescending(r => r.CreatedAt))
                        {
                            <div class="timeline-item pb-4">
                                <div class="timeline-marker bg-gov-blue"></div>
                                <div class="timeline-content ps-3">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <h6 class="mb-0 fw-bold small text-gov-blue">@remark.UserName</h6>
                                        <span class="badge bg-light text-muted extra-small p-1 border rounded-pill px-2">@remark.Role</span>
                                    </div>
                                    <p class="small text-secondary mt-1 mb-1 italic">"@remark.Comment"</p>
                                    <p class="extra-small text-muted mb-0">@remark.CreatedAt.ToString("MMM dd, yyyy HH:mm")</p>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <a asp-action="Index" class="btn btn-link text-muted extra-small d-block text-center text-decoration-none">← Back to Dashboard Queue</a>
        </div>
    </div>
</div>

<style>
    body { background-color: #f8f9fa; }
    .extra-small { font-size: 0.7rem; }
    .letter-spacing { letter-spacing: 0.5px; }
    .fw-600 { font-weight: 600; }
    .italic { font-style: italic; }

    /* Timeline Styles */
    .timeline { border-left: 2px solid #e9ecef; position: relative; }
    .timeline-item { position: relative; }
    .timeline-marker {
        position: absolute;
        left: -8px; top: 0;
        width: 14px; height: 14px;
        border-radius: 50%;
        border: 2px solid white;
    }
</style>
