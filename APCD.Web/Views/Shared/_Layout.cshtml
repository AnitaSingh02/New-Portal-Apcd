<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - APCD Portal | NPC</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <div class="gov-top-bar py-2 text-white" style="background-color: var(--primary-blue); font-size: 0.85rem;">
        <div class="container d-flex justify-content-between align-items-center">
            <div class="d-flex gap-4">
                <img src="~/images/npc-logo.png" />
            </div>
            <div class="d-flex flex-column align-items-center">
                <span class="fw-semibold fs-5">APCD OEM Empanelment Portal</span>
                <p class="mb-0">National Productivity Council for CPCB</p>
            </div>
            <div class="d-flex gap-3">
                <img src="~/images/apcd-logo-mobile.png" />
            </div>
        </div>
    </div>

    <header class="sticky-top">
    <nav class="navbar navbar-expand-lg navbar-gov shadow-sm">
        <div class="container">

            <!-- Mobile Toggle -->
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">

                <!-- Left Menu -->
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#process">Process</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#fees">Fees</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#faq">FAQ</a>
                    </li>
                </ul>

                <!-- Right Buttons -->
                <div class="d-flex align-items-center">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <a class="btn btn-primary-custom me-2" asp-controller="Dashboard" asp-action="Index">
                            Dashboard
                        </a>

                        <form asp-controller="Auth" asp-action="Logout" method="post">
                            <button type="submit" class="btn btn-outline-dark btn-sm">
                                Logout
                            </button>
                        </form>
                    }
                    else
                    {
                        <a class="btn btn-outline-primary btn-sm px-4 me-2"
                           asp-controller="Auth" asp-action="Login">
                            Sign In
                        </a>

                        <a class="btn btn-primary-custom btn-sm"
                           asp-controller="Auth" asp-action="Register">
                            Register Now
                        </a>
                    }
                </div>

            </div>
        </div>
    </nav>
</header>

    <main role="main">
        @RenderBody()
    </main>

    <footer class="footer-gov mt-0">
        <div class="container">
            <div class="row g-5">
                <div class="col-lg-4">
                    <img src="~/images/apcd-logo.png" alt="NPC Logo" height="60" class="mb-4 brightness-0 invert">
                    <p class="small text-light">NPC is a national-level organization to promote productivity culture in India. Established by the Ministry of Industry, Government of India in 1958.</p>
                    <div class="mt-4">
                        <h6 class="text-white mb-3">Newsletter</h6>
                        <div class="input-group mb-3">
                            <input type="text" class="form-control bg-dark border-secondary text-white" placeholder="Email Address">
                            <button class="btn btn-primary" type="button">Subscribe</button>
                        </div>
                    </div>
                </div>
                <div class="col-lg-2 col-md-4">
                    <h5>Quick Links</h5>
                    <ul class="list-unstyled">
                        <li><a href="#" class="footer-link small mb-2 d-block">About NPC</a></li>
                        <li><a href="#" class="footer-link small mb-2 d-block">CPCB Guidelines</a></li>
                        <li><a href="#" class="footer-link small mb-2 d-block">Empanelment Process</a></li>
                        <li><a href="#" class="footer-link small mb-2 d-block">Technical Committee</a></li>
                    </ul>
                </div>
                <div class="col-lg-2 col-md-4">
                    <h5>Support</h5>
                    <ul class="list-unstyled">
                        <li><a href="#" class="footer-link small mb-2 d-block">Help Desk</a></li>
                        <li><a href="#" class="footer-link small mb-2 d-block">FAQs</a></li>
                        <li><a href="#" class="footer-link small mb-2 d-block">Privacy Policy</a></li>
                        <li><a href="#" class="footer-link small mb-2 d-block">Terms of Service</a></li>
                    </ul>
                </div>
                <div class="col-lg-4 col-md-4">
                    <h5>Contact Us</h5>
                    <div class="d-flex mb-3">
                        <i class="bi bi-geo-alt-fill text-primary me-3"></i>
                        <span class="small">Utpadakta Bhawan, 5-6 Institutional Area, Lodhi Road, New Delhi - 110003</span>
                    </div>
                    <div class="d-flex mb-3">
                        <i class="bi bi-telephone-fill text-primary me-3"></i>
                        <span class="small">+91-11-24690331, 24607344</span>
                    </div>
                    <div class="d-flex">
                        <i class="bi bi-envelope-fill text-primary me-3"></i>
                        <span class="small">apcd-support@npcindia.gov.in</span>
                    </div>
                </div>
            </div>
            <hr class="mt-5 border-secondary">
            <div class="row py-4 align-items-center">
                <div class="col-md-6 text-center text-md-start">
                    <p class="small mb-0">&copy; @DateTime.Now.Year National Productivity Council. All rights reserved.</p>
                </div>
                <div class="col-md-6 text-center text-md-end">
                    <p class="small mb-0">Designed & Developed by IT Group, NPC</p>
                </div>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
