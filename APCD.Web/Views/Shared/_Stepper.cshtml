@model int
@{
    var activeStep = Model;
    var steps = new[]
    {
        new { Name = "Profile", Icon = "bi-person-badge" },
        new { Name = "Categories", Icon = "bi-list-check" },
        new { Name = "Documents", Icon = "bi-file-earmark-arrow-up" },
        new { Name = "Installations", Icon = "bi-building-gear" },
        new { Name = "Review", Icon = "bi-eye" },
        new { Name = "Payment", Icon = "bi-credit-card" }
    };
}

<div class="stepper animate-fade-in mb-5">
    @for (int i = 0; i < steps.Length; i++)
    {
        var stepNum = i + 1;
        var statusClass = "";
        if (stepNum == activeStep) statusClass = "active";
        else if (stepNum < activeStep) statusClass = "completed";

        <div class="step-item @statusClass">
            <div class="step-circle">
                @if (stepNum < activeStep)
                {
                    <i class="bi bi-check-lg"></i>
                }
                else
                {
                    <i class="bi @steps[i].Icon"></i>
                }
            </div>
            <div class="step-label">@steps[i].Name</div>
        </div>
    }
</div>
