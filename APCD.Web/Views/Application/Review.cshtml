@model APCD.Web.Models.EmpanelmentApplication

@{
    ViewData["Title"] = "Review & Submit";
}

<div class="container py-5">
    <partial name="_Stepper" model="5" />
    <div class="row justify-content-center">
        <div class="col-md-11">
            <div class="card shadow-sm border-0 animate-fade-in">
                <div class="card-header bg-gov-blue text-white py-3 d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 fw-bold">Final Review & Submission</h5>
                    <span class="badge bg-warning text-dark">Status: @Model.Status</span>
                </div>
                <div class="card-body p-4">
                    <div class="alert alert-warning mb-4 py-2 small">
                        Please review all the information below carefully. Once submitted, you will not be able to edit your application.
                    </div>

                    <div class="row g-4">
                        <div class="col-md-6">
                            <div class="border rounded p-3 h-100">
                                <h6 class="fw-bold mb-3 border-bottom pb-2 text-primary">Company Info</h6>
                                <p class="mb-1 small"><strong>Name:</strong> @Model.User.FullName</p>
                                <p class="mb-1 small"><strong>Email:</strong> @Model.User.Email</p>
                                <p class="mb-1 small"><strong>Categories:</strong> @Model.SelectedAPCDCategories</p>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="border rounded p-3 h-100">
                                <h6 class="fw-bold mb-3 border-bottom pb-2 text-primary">Documents (@Model.Documents.Count)</h6>
                                <ul class="list-unstyled mb-0 small">
                                    @foreach (var doc in Model.Documents)
                                    {
                                        <li class="d-flex justify-content-between align-items-center mb-1">
                                            <span><i class="bi bi-file-earmark-check text-success me-1"></i> @doc.DocumentType</span>
                                            <a href="@doc.FilePath" target="_blank" class="text-decoration-none extra-small"><i class="bi bi-eye"></i> View</a>
                                        </li>
                                    }
                                </ul>
                            </div>
                        </div>
                        <div class="col-12">
                            <div class="border rounded p-3">
                                <h6 class="fw-bold mb-3 border-bottom pb-2 text-primary">Installation Records (@Model.Installations.Count)</h6>
                                <div class="table-responsive">
                                    <table class="table table-sm text-muted small">
                                        <thead>
                                            <tr>
                                                <th>Client</th>
                                                <th>Location</th>
                                                <th>Date</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var record in Model.Installations)
                                            {
                                                <tr>
                                                    <td>@record.ClientName</td>
                                                    <td>@record.Location</td>
                                                    <td>@record.InstallationDate.ToShortDateString()</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="mt-5 p-4 bg-light rounded">
                        <div class="form-check mb-3">
                            <input class="form-check-input" type="checkbox" id="declaration" required />
                            <label class="form-check-label small" for="declaration">
                                I hereby declare that all information provided in this application is true and correct to the best of my knowledge and belief. I understand that any false information may lead to rejection of this application.
                            </label>
                        </div>
                    </div>

                    <div class="mt-4 d-flex justify-content-between">
                        <a asp-action="Step3" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Previous</a>
                        @if (Model.Payment == null)
                        {
                            <a asp-action="Payment" asp-route-id="@Model.Id" class="btn btn-gov-primary px-5 fw-bold shadow-sm">
                                Proceed to Payment <i class="bi bi-arrow-right ms-1"></i>
                            </a>
                        }
                        else
                        {
                            <form asp-action="Submit" asp-route-id="@Model.Id" method="post">
                                <button type="submit" class="btn btn-success px-5 fw-bold shadow-sm">
                                    Final Submit <i class="bi bi-send ms-1"></i>
                                </button>
                            </form>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
