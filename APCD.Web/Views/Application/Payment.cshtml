@model APCD.Web.Models.PaymentDetail
@{
    ViewData["Title"] = "Payment Acknowledgment";
}

<div class="container py-5">
    <partial name="_Stepper" model="6" />
    <div class="row justify-content-center">
        <div class="col-md-9">
            <div class="card shadow border-0 rounded-4 overflow-hidden animate-fade-in">
                <div class="card-header bg-gov-blue text-white py-3">
                    <h5 class="mb-0 fw-bold">Empanelment Fee Acknowledgment</h5>
                </div>
                <div class="card-body p-4 p-lg-5">
                    
                    <!-- Invoice Breakdown -->
                    <div class="row mb-5">
                        <div class="col-lg-7">
                            <h6 class="fw-bold text-muted mb-4 text-uppercase small letter-spacing">Invoice Summary</h6>
                            <div class="d-flex justify-content-between mb-2">
                                <span>Base Application Fee</span>
                                <span class="fw-600">₹@ViewBag.BaseFee.ToString("N0")</span>
                            </div>
                            <div class="d-flex justify-content-between mb-2 pb-2 border-bottom">
                                <span>Product Fees (@ViewBag.CategoryCount categories)</span>
                                <span class="fw-600">₹@ViewBag.ProductFees.ToString("N0")</span>
                            </div>
                            <div class="d-flex justify-content-between mt-2">
                                <span class="text-muted">Subtotal</span>
                                <span class="fw-bold">₹@((ViewBag.BaseFee + ViewBag.ProductFees).ToString("N0"))</span>
                            </div>
                            <div class="d-flex justify-content-between mb-4">
                                <span class="text-muted">GST (18%)</span>
                                <span class="text-muted">₹@ViewBag.GST.ToString("N0")</span>
                            </div>
                            <div class="d-flex justify-content-between p-3 bg-light rounded-3 border-start border-4 border-gov-gold">
                                <span class="fw-bold">Total Amount Payable</span>
                                <h4 class="fw-bold text-gov-blue mb-0">₹@ViewBag.Total.ToString("N0")</h4>
                            </div>
                        </div>
                        <div class="col-lg-5 d-none d-lg-flex align-items-center justify-content-center">
                            <div class="text-center p-4 bg-light rounded-4 w-100 border border-dashed">
                                <i class="bi bi-receipt text-gov-blue opacity-25" style="font-size: 5rem;"></i>
                            </div>
                        </div>
                    </div>

                    <div class="row g-4 mb-5">
                        <div class="col-md-7">
                            <div class="p-4 bg-gov-light-blue rounded-4 border-0">
                                <h6 class="fw-bold text-gov-blue mb-3"><i class="bi bi-bank me-2"></i>Bank Details for NEFT/RTGS</h6>
                                <div class="small text-muted mb-1">Bank Name</div>
                                <div class="fw-bold mb-2">State Bank of India</div>
                                <div class="small text-muted mb-1">Account Name</div>
                                <div class="fw-bold mb-2">National Productivity Council (NPC)</div>
                                <div class="small text-muted mb-1">Account Number</div>
                                <div class="fw-bold mb-2">1234567890</div>
                                <div class="small text-muted mb-1">IFSC Code</div>
                                <div class="fw-bold">SBIN0001234</div>
                            </div>
                        </div>
                        <div class="col-md-5 text-center">
                            <h6 class="fw-bold mb-3">Scan to pay via UPI</h6>
                            <img src="https://api.qrserver.com/v1/create-qr-code/?size=150x150&data=upi://pay?pa=npcindia@sbi&pn=NPC&am=@ViewBag.Total" class="img-fluid rounded border p-2 mb-2 shadow-sm" alt="Payment QR" />
                            <p class="extra-small text-muted mb-0">Powered by BharatQR</p>
                        </div>
                    </div>

                    <form asp-action="Payment" asp-route-id="@Model.ApplicationId" method="post">
                        <input type="hidden" name="Amount" value="@ViewBag.Total" />
                        
                        <div class="mb-4">
                            <label class="form-label fw-bold text-gov-blue">Transaction Reference / UTR Number</label>
                            <div class="input-group input-group-lg shadow-sm">
                                <span class="input-group-text bg-white border-end-0"><i class="bi bi-hash text-muted"></i></span>
                                <input type="text" name="UTRNumber" class="form-control border-start-0 fs-5" placeholder="Enter bank reference number" required />
                            </div>
                            <div class="form-text mt-2"><i class="bi bi-info-circle me-1"></i> Please provide the 12-digit UTR number shared by your bank for verification.</div>
                        </div>

                        <div class="d-flex justify-content-between mt-5 pt-3 border-top">
                            <a asp-action="Review" asp-route-id="@Model.ApplicationId" class="btn btn-link text-muted text-decoration-none">← Back to Review</a>
                            <button type="submit" class="btn btn-gov-primary btn-lg px-5 shadow-sm rounded-pill font-weight-bold">
                                Confirm & Submit Application <i class="bi bi-arrow-right-short ms-1"></i>
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .letter-spacing { letter-spacing: 1px; }
    .extra-small { font-size: 0.75rem; }
</style>
