@model APCD.Web.Models.EmpanelmentApplication
@{
    ViewData["Title"] = "Application Submitted";
}

<div class="container py-5 mt-5 animate-fade-in text-center">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card shadow border-0 rounded-4 p-5 overflow-hidden position-relative">
                <div class="gov-stripe position-absolute top-0 start-0 end-0"></div>
                
                <div class="mb-4">
                    <div class="bg-success text-white rounded-circle d-inline-flex align-items-center justify-content-center shadow-lg" style="width: 100px; height: 100px;">
                        <i class="bi bi-check-lg" style="font-size: 4rem;"></i>
                    </div>
                </div>

                <h2 class="fw-bold text-gov-blue mb-3">Application Submitted Successfully!</h2>
                <p class="text-muted fs-5 mb-4 px-lg-5">Your empanelment application has been received. Our team will verify your details and payment information (UTR: <strong>@Model.Payment?.UTRNumber</strong>).</p>

                <div class="bg-light rounded-3 p-4 mb-5 border border-success-subtle">
                    <div class="row text-start align-items-center">
                        <div class="col-sm-6 border-end-sm">
                            <small class="text-muted d-block mb-1">Application ID</small>
                            <h4 class="fw-bold text-gov-blue mb-0">#@Model.Id.ToString("0000")</h4>
                        </div>
                        <div class="col-sm-6 mt-3 mt-sm-0">
                            <small class="text-muted d-block mb-1">Current Status</small>
                            <span class="badge bg-success-subtle text-success border border-success-subtle rounded-pill px-3">Verification Pending</span>
                        </div>
                    </div>
                </div>

                <div class="d-flex flex-column flex-sm-row gap-3 justify-content-center">
                    <a asp-controller="Dashboard" asp-action="Index" class="btn btn-gov-primary px-5 py-3 rounded-pill fw-bold shadow-sm">
                        Go to Dashboard <i class="bi bi-house-door ms-1"></i>
                    </a>
                    <button onclick="window.print()" class="btn btn-outline-secondary px-5 py-3 rounded-pill">
                        Print Acknowledgment <i class="bi bi-printer ms-1"></i>
                    </button>
                </div>

                <div class="mt-5 pt-4 border-top">
                    <p class="small text-muted">A confirmation email has been sent to <strong>@Model.User.Email</strong>.</p>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    body { background-color: #f8f9fa; }
    @@media (min-width: 576px) {
        .border-end-sm { border-right: 1px solid #dee2e6 !important; }
    }
</style>
