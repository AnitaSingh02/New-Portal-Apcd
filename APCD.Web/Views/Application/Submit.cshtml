@model APCD.Web.Models.EmpanelmentApplication
@{
    ViewData["Title"] = "Application Submitted";
    int currentStep = 8;
}

@section Styles {
    <link rel="stylesheet" href="~/css/application-form.css" asp-append-version="true" />
}

<div class="container py-5">
    <div class="card wizard-container border-0 shadow-lg p-0">
        <div class="row g-0">
            <!-- Sidebar -->
            <div class="col-lg-3">
                <partial name="_WizardSidebar" model="currentStep" />
            </div>

            <!-- Main Content -->
            <div class="col-lg-9 bg-white">
                <div class="wizard-main text-center py-5">
                    <div class="mb-5">
                        <div class="rounded-circle bg-success bg-opacity-10 d-inline-flex align-items-center justify-content-center" style="width: 100px; height: 100px;">
                            <i class="bi bi-check-circle-fill text-success" style="font-size: 3.5rem;"></i>
                        </div>
                    </div>

                    <h2 class="fw-bold text-primary mb-3">Application Submitted Successfully!</h2>
                    <p class="text-muted fs-5 mb-5 mx-lg-5 px-lg-4">Your empanelment application for the Air Pollution Control Device (APCD) Scheme has been received and is currently under review by the NPC Technical Committee.</p>

                    <div class="row justify-content-center mb-5">
                        <div class="col-md-6">
                            <div class="p-4 rounded-4 border bg-light shadow-sm">
                                <div class="small fw-bold text-muted mb-2 text-uppercase">Your Application ID</div>
                                <h3 class="fw-bold text-dark mb-0">APC-@Model.Id.ToString("D5")</h3>
                                <hr class="my-3">
                                <div class="d-flex justify-content-between text-start mb-2">
                                    <span class="small text-muted">Status</span>
                                    <span class="badge bg-warning text-dark px-3 py-2">@Model.Status</span>
                                </div>
                                <div class="d-flex justify-content-between text-start">
                                    <span class="small text-muted">Submitted On</span>
                                    <span class="small fw-bold text-dark">@Model.SubmittedAt?.ToString("dd MMM yyyy, HH:mm")</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="bg-primary bg-opacity-5 p-4 rounded-4 text-start mx-lg-5 mb-5">
                        <h6 class="fw-bold mb-3">What happens next?</h6>
                        <ul class="list-unstyled small text-dark mb-0">
                            <li class="mb-2"><i class="bi bi-1-circle-fill text-primary me-2"></i> <strong>Document Verification:</strong> Our dealing hand will verify all your uploaded documents and payment UTR.</li>
                            <li class="mb-2"><i class="bi bi-2-circle-fill text-primary me-2"></i> <strong>Desk Review:</strong> A technical committee will perform a desk review of your manufacturing capabilities.</li>
                            <li class="mb-2"><i class="bi bi-3-circle-fill text-primary me-2"></i> <strong>Field Visit:</strong> A field verification team may schedule a visit to your unit location to confirm GPS and factory details.</li>
                            <li><i class="bi bi-4-circle-fill text-primary me-2"></i> <strong>Empanelment Decision:</strong> Final empanelment status will be communicated via email and your dashboard.</li>
                        </ul>
                    </div>

                    <div class="d-flex gap-3 justify-content-center">
                        <a asp-controller="Dashboard" asp-action="Index" class="btn btn-primary-custom px-5 py-3">
                            <i class="bi bi-speedometer2 me-2"></i> Go to Dashboard
                        </a>
                        <a asp-action="Print" asp-route-id="@Model.Id" target="_blank" class="btn btn-outline-dark px-5 py-3">
                            <i class="bi bi-printer me-2"></i> Print Application
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
