@model int
@{
    int currentStep = Model;
    var steps = new[]
    {
        new { Name = "Applicant Details", Icon = "1" },
        new { Name = "Classifications", Icon = "2" },
        new { Name = "Key Personnel", Icon = "3" },
        new { Name = "Technical Scope", Icon = "4" },
        new { Name = "Financials", Icon = "5" },
        new { Name = "Review", Icon = "6" },
        new { Name = "Payment", Icon = "7" },
        new { Name = "Final Submit", Icon = "8" }
    };
}

<div class="wizard-sidebar h-100">
    <div class="px-4 mb-4">
        <h5 class="fw-bold text-primary mb-0">Application Progress</h5>
        <p class="extra-small text-muted">Complete all steps to submit</p>
    </div>
    <div class="list-group list-group-flush">
        @for (int i = 0; i < steps.Length; i++)
        {
            var stepNum = i + 1;
            var isActive = stepNum == currentStep;
            var isCompleted = stepNum < currentStep;
            var stepClass = isActive ? "active" : (isCompleted ? "completed" : "");
            var actionName = stepNum == 1 ? "Profile" : 
                            stepNum == 6 ? "Review" : 
                            stepNum == 7 ? "Payment" : 
                            stepNum == 8 ? "Submit" : $"Step{stepNum}";

            <div class="wizard-step @stepClass">
                <div class="wizard-step-icon">
                    @if (isCompleted)
                    {
                        <i class="bi bi-check-lg"></i>
                    }
                    else
                    {
                        @steps[i].Icon
                    }
                </div>
                <div class="d-flex flex-column">
                    <span class="small opacity-75">Step @stepNum</span>
                    <span class="fw-semibold">@steps[i].Name</span>
                </div>
            </div>
        }
    </div>
</div>
