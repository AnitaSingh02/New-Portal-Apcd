@model APCD.Web.Models.EmpanelmentApplication

@{
    ViewData["Title"] = "Installation Experience";
}

<div class="container py-5">
    <partial name="_Stepper" model="4" />
    <div class="row justify-content-center">
        <div class="col-md-11">
            <div class="card shadow-sm border-0 animate-fade-in">
                <div class="card-header bg-gov-blue text-white py-3">
                    <h5 class="mb-0 fw-bold">Installation Experience</h5>
                </div>
                <div class="card-body p-4">
                    <p class="text-muted small mb-4">Provide details of at least 3 successful APCD installations completed by your company in the last 3 years.</p>
                    
                    <div class="row g-4 mb-5">
                        <div class="col-lg-4">
                            <div class="card bg-light border-0 p-3">
                                <h6 class="fw-bold mb-3">Add New Record</h6>
                                <form asp-action="AddInstallation" asp-route-id="@Model.Id" method="post">
                                    <div class="mb-2">
                                        <label class="form-label small fw-bold">Client Name</label>
                                        <input type="text" name="ClientName" class="form-control form-control-sm" required />
                                    </div>
                                    <div class="mb-2">
                                        <label class="form-label small fw-bold">Location (City, State)</label>
                                        <input type="text" name="Location" class="form-control form-control-sm" required />
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label small fw-bold">Installation Date</label>
                                        <input type="date" name="InstallationDate" class="form-control form-control-sm" required />
                                    </div>
                                    <div class="d-grid">
                                        <button type="submit" class="btn btn-primary btn-sm">Add Record</button>
                                    </div>
                                </form>
                            </div>
                        </div>
                        <div class="col-lg-8">
                            <h6 class="fw-bold mb-3">Recorded Installations (@Model.Installations.Count)</h6>
                            @if (Model.Installations.Any())
                            {
                                <div class="table-responsive">
                                    <table class="table table-sm table-striped">
                                        <thead>
                                            <tr>
                                                <th>Client</th>
                                                <th>Location</th>
                                                <th>Date</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var record in Model.Installations)
                                            {
                                                <tr>
                                                    <td>@record.ClientName</td>
                                                    <td>@record.Location</td>
                                                    <td>@record.InstallationDate.ToShortDateString()</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                            else
                            {
                                <div class="alert alert-info py-2 small">No installation records added yet.</div>
                            }
                        </div>
                    </div>

                    <div class="mt-5 d-flex justify-content-between">
                        <a asp-action="Step2" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Previous</a>
                        <a asp-action="Review" asp-route-id="@Model.Id" class="btn @(Model.Installations.Count >= 3 ? "btn-primary" : "btn-outline-primary disabled") px-5">Continue to Review</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
