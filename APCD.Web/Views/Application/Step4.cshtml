@model List<APCD.Web.Models.APCDCapability>
@{
    ViewData["Title"] = "Technical Scope";
    int currentStep = 4;
    var appId = ViewBag.AppId;

    var technologies = new[] {
        new { Main = "ESP", Subs = new[] { "Dry ESP (Plate/Tube Type)", "Wet ESP" } },
        new { Main = "Bag Filter/ Baghouse Systems", Subs = new[] { "Pulse Jet Baghouse", "Reverse Air Baghouse", "Mechanical Shaker Baghouse" } },
        new { Main = "Cyclones", Subs = new[] { "Single Cyclone", "Twin Cyclone", "Multi Cyclone / Multi-Clone", "High-Efficiency Cyclone" } },
        new { Main = "Wet Scrubber", Subs = new[] { "Venturi Scrubber", "Spray Tower / Spray Scrubber", "Packed Bed Scrubber", "Submerged Scrubber", "Multi-Stage Wet Scrubber" } },
        new { Main = "Dry Scrubber", Subs = new[] { "Dry Sorbent Injection", "Semi-Dry Scrubber" } },
        new { Main = "Hybrid/ other", Subs = new[] { "Hybrid ESP–Baghouse", "Hybrid Wet–Dry Scrubbers", "Electrostatic Gravel Bed", "New advance/ patented /Hybrid technologies /Others" } },
        new { Main = "Industrial fume/dust extraction system (except APCD)", Subs = new[] { "Standard System" } }
    };
}

@section Styles {
    <link rel="stylesheet" href="~/css/application-form.css" asp-append-version="true" />
}

<div class="container py-4">
    <div class="card wizard-container border-0 shadow-lg">
        <div class="row g-0">
            <!-- Sidebar -->
            <div class="col-lg-3">
                <partial name="_WizardSidebar" model="currentStep" />
            </div>

            <!-- Main Content -->
            <div class="col-lg-9 bg-white">
                <div class="wizard-main">
                    <form asp-action="SaveCapabilities" asp-route-id="@appId" method="post" enctype="multipart/form-data">
                        <div class="form-section-title">Step 4: Technical Scope (APCD Technologies)</div>
                        <p class="text-muted small mb-4">Point 21: Specify the APCDs currently manufactured and those for which empanelment is sought.</p>

                        <div class="table-responsive border rounded-4 overflow-hidden mb-4">
                            <table class="table tech-matrix-table mb-0 align-middle">
                                <thead style="background-color: #c9daf8;">
                                    <tr>
                                        <th style="width: 18%;">Sl. No. & Main Technology</th>
                                        <th style="width: 25%;">Type of APCDs based on technology</th>
                                        <th class="text-center bg-light text-dark" style="width: 12%;">Pt 21: Mfgr.<br/><small class="fw-normal">Yes/No</small></th>
                                        <th class="text-center bg-light text-dark" style="width: 12%;">Pt 22: Apply<br/><small class="fw-normal">Yes/No</small></th>
                                        <th class="text-center" style="width: 15%;">Pt 21: Category<br/><small class="fw-normal">(1/2/Both)</small></th>
                                        <th style="width: 18%;">Designed Capacity<br/><small class="fw-normal">(give range)</small></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @{ 
                                        int i = 0; 
                                        int mainTechCounter = 1;
                                    }
                                    @foreach (var tech in technologies)
                                    {
                                        bool isFirst = true;
                                        @foreach (var sub in tech.Subs)
                                        {
                                            var existing = Model.FirstOrDefault(c => c.MainType == tech.Main && c.SubTech == sub);
                                            bool isLocked = ViewBag.IsAddMoreMode == true && existing?.IsAppliedForEmpanelment == true;
                                            
                                            <tr class="data-grid-row @(isLocked ? "bg-light opacity-75" : "")">
                                                @if (isFirst)
                                                {
                                                    <td rowspan="@tech.Subs.Length" class="fw-bold bg-light">
                                                        @mainTechCounter. @tech.Main
                                                    </td>
                                                    isFirst = false;
                                                }
                                                <td class="small pt-3 pb-3">
                                                    @sub
                                                    @if (sub.Contains("patented") || sub.Contains("Others"))
                                                    {
                                                        <div class="mt-2 pt-2 border-top border-light">
                                                            <strong class="text-dark small mb-1 d-block">If yes, specify the type:</strong>
                                                            @if (isLocked)
                                                            {
                                                                <input type="text" class="form-control form-control-sm" value="@existing?.TypeDetails" disabled />
                                                                <input type="hidden" name="capabilities[@i].TypeDetails" value="@existing?.TypeDetails" />
                                                            }
                                                            else
                                                            {
                                                                <input type="text" name="capabilities[@i].TypeDetails" class="form-control form-control-sm" placeholder="__________________" value="@existing?.TypeDetails" />
                                                            }
                                                        </div>
                                                    }
                                                </td>
                                                <td class="text-center bg-light">
                                                    <input type="hidden" name="capabilities[@i].MainType" value="@tech.Main" />
                                                    <input type="hidden" name="capabilities[@i].SubTech" value="@sub" />
                                                    <div class="form-check d-flex justify-content-center mb-0">
                                                        @if (isLocked)
                                                        {
                                                            <input type="checkbox" class="form-check-input mt-0" style="width: 1.25em; height: 1.25em;" checked disabled />
                                                            <input type="hidden" name="capabilities[@i].IsManufactured" value="true" />
                                                        }
                                                        else
                                                        {
                                                            <input type="checkbox" name="capabilities[@i].IsManufactured" value="true" class="form-check-input mt-0" style="width: 1.25em; height: 1.25em;" @(existing?.IsManufactured == true ? "checked" : "") />
                                                            <input type="hidden" name="capabilities[@i].IsManufactured" value="false" />
                                                        }
                                                    </div>
                                                </td>
                                                <td class="text-center bg-light">
                                                    <div class="form-check d-flex justify-content-center mb-0">
                                                        @if (isLocked)
                                                        {
                                                            <input type="checkbox" class="form-check-input mt-0" style="width: 1.25em; height: 1.25em;" checked disabled />
                                                            <input type="hidden" name="capabilities[@i].IsAppliedForEmpanelment" value="true" />
                                                        }
                                                        else
                                                        {
                                                            <input type="checkbox" name="capabilities[@i].IsAppliedForEmpanelment" value="true" class="form-check-input mt-0 tech-apply-checkbox" data-tech-name="@sub" style="width: 1.25em; height: 1.25em;" @(existing?.IsAppliedForEmpanelment == true ? "checked" : "") />
                                                            <input type="hidden" name="capabilities[@i].IsAppliedForEmpanelment" value="false" />
                                                        }
                                                    </div>
                                                </td>
                                                <td>
                                                    @if (isLocked)
                                                    {
                                                        <select class="form-select form-select-sm" disabled>
                                                            <option value="@existing?.Category" selected>@existing?.Category</option>
                                                        </select>
                                                        <input type="hidden" name="capabilities[@i].Category" value="@existing?.Category" />
                                                    }
                                                    else
                                                    {
                                                        <select name="capabilities[@i].Category" class="form-select form-select-sm">
                                                            <option value="">NA</option>
                                                            <option value="1" selected="@(existing?.Category == "1")">1</option>
                                                            <option value="2" selected="@(existing?.Category == "2")">2</option>
                                                            <option value="both" selected="@(existing?.Category == "both")">Both</option>
                                                        </select>
                                                    }
                                                </td>
                                                <td>
                                                    @if (isLocked)
                                                    {
                                                        <input class="form-control form-control-sm" value="@existing?.DesignedCapacity" disabled />
                                                        <input type="hidden" name="capabilities[@i].DesignedCapacity" value="@existing?.DesignedCapacity" />
                                                    }
                                                    else
                                                    {
                                                        <input name="capabilities[@i].DesignedCapacity" class="form-control form-control-sm" placeholder="e.g. 500-2000 CFM" value="@existing?.DesignedCapacity" />
                                                    }
                                                </td>
                                            </tr>
                                            i++;
                                        }
                                        mainTechCounter++;
                                    }
                                </tbody>
                            </table>
                        </div>

                        <div class="alert alert-info py-3 small mb-5">
                            <h6 class="fw-bold mb-2"><i class="bi bi-info-circle-fill me-2"></i>Note on Empanelment Categories:</h6>
                            <b class="text-dark">Category 1:</b> APCDs installed on Boilers / Furnaces / Thermic Fluid Heaters (TFH) flue-gas emission control.<br/> 
                            <b class="text-dark">Category 2:</b> APCDs installed on Non-Boiler / Non-Furnace / Non-TFH/ Non-heat dust/gas emission control.<br/>
                            <span class="d-inline-block mt-2">If you have past experience in installing the relevant APCD under both Category 1 and Category 2, please select '<strong>Both</strong>' in the drop-down above. If not, please indicate category '1' or '2', as applicable.</span>
                        </div>

                        <!-- Point 22: Installations Table -->
                        <div class="mb-5">
                            <h5 class="fw-bold text-dark mb-3">22. Provide details of installations completed in the last three (3) years (minimun five) including:</h5>
                            <div class="table-responsive border rounded-4 overflow-hidden shadow-sm">
                                <table class="table table-bordered mb-0 align-middle">
                                    <thead style="background-color: #f1f3f4;">
                                        <tr class="text-center text-dark">
                                            <th style="width: 5%;">SN</th>
                                            <th style="width: 20%;">Client Name</th>
                                            <th style="width: 10%;">Year</th>
                                            <th style="width: 17%;">Type of APCD</th>
                                            <th style="width: 16%;">Capacity/Size</th>
                                            <th style="width: 15%;">Performance Result<br/><small>(if any)</small></th>
                                            <th style="width: 17%;">Upload Certificate</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @{
                                            var instList = ViewBag.Installations as List<APCD.Web.Models.InstallationRecord> ?? new List<APCD.Web.Models.InstallationRecord>();
                                            int maxRows = Math.Max(5, instList.Count);
                                        }
                                        @for (int j = 0; j < maxRows; j++)
                                        {
                                            var inst = j < instList.Count ? instList[j] : null;
                                            <tr>
                                                <td class="text-center fw-bold bg-light">
                                                    @(j + 1)
                                                </td>
                                                <td><input type="text" name="installations[@j].ClientName" class="form-control form-control-sm border-0" value="@inst?.ClientName" @(j < 5 ? "required" : "") /></td>
                                                <td><input type="number" name="installations[@j].Year" class="form-control form-control-sm border-0 text-center" value="@inst?.Year" @(j < 5 ? "required" : "") /></td>
                                                <td><input type="text" name="installations[@j].ApcdType" class="form-control form-control-sm border-0" value="@inst?.ApcdType" @(j < 5 ? "required" : "") /></td>
                                                <td><input type="text" name="installations[@j].Capacity" class="form-control form-control-sm border-0" value="@inst?.Capacity" @(j < 5 ? "required" : "") /></td>
                                                <td><input type="text" name="installations[@j].PerformanceResult" class="form-control form-control-sm border-0" value="@inst?.PerformanceResult" /></td>
                                                <td>
                                                    <input type="hidden" name="installations[@j].PerformanceCertPath" value="@inst?.PerformanceCertPath" />
                                                    <input type="file" name="PerformanceCertFile_@j" class="form-control form-control-sm border-0" accept=".pdf" @(j < 5 && string.IsNullOrEmpty(inst?.PerformanceCertPath) ? "required" : "") />
                                                    @if (!string.IsNullOrEmpty(inst?.PerformanceCertPath)) {
                                                        <a href="@inst.PerformanceCertPath" target="_blank" class="extra-small text-success mt-1 d-inline-block text-decoration-none"><i class="bi bi-file-earmark-check me-1"></i>View Uploaded</a>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>

                        <!-- Section E & F Summary -->
                        <div class="row g-4 mt-5">
                            <div class="col-md-12">
                                <h5 class="fw-bold mb-1 text-primary"><i class="bi bi-file-earmark-pdf me-2"></i> Section E & F: Technical Documents & Experience</h5>
                                <p class="text-muted small">Upload mandatory technical documents for each technology applied for empanelment.</p>
                            </div>
                            
                            @{ var docs = ViewBag.Documents as List<APCD.Web.Models.ApplicationDocument>; }

                            <!-- Technical Catalogues (Global) -->
                            <div class="col-md-6">
                                <div class="p-3 border rounded-3 bg-light h-100 shadow-sm border-primary-subtle">
                                    <label class="form-group-label fw-bold text-dark">13. Technical Catalogues / Brochures <span class="text-danger">*</span></label>
                                    <input type="file" name="techCatalogueFile" class="form-control form-control-sm mt-3" accept=".pdf" @(docs != null && docs.Any(d => d.DocumentType == "TechnicalCatalogue") ? "" : "required") />
                                    @if (docs != null && docs.Any(d => d.DocumentType == "TechnicalCatalogue"))
                                    {
                                        var tmpDoc = docs.First(d => d.DocumentType == "TechnicalCatalogue");
                                        <div class="mt-2 pt-2 border-top border-white"><i class="bi bi-check-circle-fill text-success"></i> <span class="small text-success fw-bold">Uploaded:</span> <a href="@tmpDoc.FilePath" target="_blank" class="small text-decoration-none fw-bold">@tmpDoc.FileName</a></div>
                                    }
                                </div>
                            </div>
                        </div>

                        <!-- Dynamic Document Containers -->
                        <div id="tech-docs-container" class="mt-4 animate-fade-in">
                            <!-- JS will inject technical document sections here -->
                        </div>
                        <!-- Navigation -->
                        <div class="mt-5 pt-4 border-top d-flex justify-content-between">
                            <a asp-action="Step3" asp-route-id="@appId" class="btn btn-wizard-prev shadow-sm">
                                <i class="bi bi-arrow-left me-2"></i> Previous
                            </a>
                            <button type="submit" class="btn btn-wizard-next shadow-sm">
                                Next Step: Financials <i class="bi bi-arrow-right ms-2"></i>
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const existingDocs = @Html.Raw(Json.Serialize(ViewBag.JsonDocuments));
        const docTypes = [
            { id: 'productDatasheetFile', label: '10. Product Datasheets', type: 'ProductDatasheet' },
            { id: 'gaDrawingFile', label: '11. General Arrangement (GA) Drawing', type: 'GADrawing' },
            { id: 'processFlowFile', label: '12. Process Flow Diagram', type: 'ProcessFlowDiagram' },
            { id: 'designCalcFile', label: '16. Design Calculations', type: 'DesignCalculation' },
            { id: 'materialConstructionFile', label: '17. Material of Construction Certificates', type: 'MaterialOfConstruction' },
            { id: 'warrantyFile', label: '18. Warranty Documents', type: 'WarrantyDocument' },
            { id: 'installationExpFile', label: '19. Experience in Installation (Annexure-6a/6b)', type: 'InstallationExperience' },
            { id: 'clientPerformanceFile', label: '20. Client Performance Certificate', type: 'ClientPerformanceCertificate' },
            { id: 'testCertificateFile', label: '25. Test Certificates (Internal/NABL)', type: 'TestCertificate' }
        ];

        function updateTechDocuments() {
            const container = document.getElementById('tech-docs-container');
            const selectedTechs = Array.from(document.querySelectorAll('.tech-apply-checkbox:checked')).map(cb => cb.dataset.techName);
            
            // Collect tech names from locked rows (hidden fields)
            document.querySelectorAll('input[type="hidden"][name$=".IsAppliedForEmpanelment"][value="true"]').forEach(el => {
                const row = el.closest('tr');
                if (row) {
                    const techCol = row.cells[1];
                    if (techCol) {
                        const techName = techCol.innerText.trim();
                        if (!selectedTechs.includes(techName)) selectedTechs.push(techName);
                    }
                }
            });

            container.innerHTML = '';

            selectedTechs.forEach(tech => {
                const section = document.createElement('div');
                section.className = 'tech-doc-section mb-5 p-4 border-start border-4 border-primary rounded-end-4 bg-light shadow-sm animate-fade-in';
                const safeTechId = tech.replace(/\s+/g, '_').replace(/[\(\)\/]/g, '_');
                
                section.innerHTML = `
                    <div class="d-flex align-items-center mb-4 border-bottom pb-2">
                        <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 32px; height: 32px;">
                            <i class="bi bi-gear-fill small"></i>
                        </div>
                        <h6 class="fw-bold text-dark mb-0">Documents for: <span class="text-primary">${tech}</span></h6>
                    </div>
                    <div class="row g-3">
                        ${docTypes.map(doc => {
                            const foundDoc = existingDocs.find(d => d.documentType === doc.type && d.associatedTech === tech);
                            const fileInputKey = `${doc.id}_${safeTechId}`;
                            return `
                                <div class="col-md-6 col-lg-4">
                                    <div class="p-3 border rounded-3 h-100 bg-white shadow-sm hover-elevate transition-all">
                                        <label class="form-label small fw-bold text-secondary mb-2">${doc.label} <span class="text-danger">*</span></label>
                                        <input type="file" name="${fileInputKey}" class="form-control form-control-sm" accept=".pdf" ${foundDoc ? '' : 'required'} />
                                        ${foundDoc ? `
                                            <div class="mt-2 text-truncate">
                                                <a href="${foundDoc.filePath}" target="_blank" class="extra-small text-success text-decoration-none fw-bold">
                                                    <i class="bi bi-file-earmark-check-fill me-1"></i>${foundDoc.fileName}
                                                </a>
                                            </div>` : ''}
                                    </div>
                                </div>
                            `;
                        }).join('')}
                    </div>
                `;
                container.appendChild(section);
            });
        }

        document.querySelectorAll('.tech-apply-checkbox').forEach(cb => {
            cb.addEventListener('change', updateTechDocuments);
        });

        // Initialize on load
        document.addEventListener('DOMContentLoaded', updateTechDocuments);
    </script>
}
