@{
    ViewData["Title"] = "Forgot Password";
    Layout = null; 
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - APCD Portal</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

<div class="auth-split-wrapper">
    <div class="auth-left-brand d-none d-lg-flex">
        <div class="auth-logo-container text-center">
            <img src="~/images/apcd-logo.png" alt="APCDES Logo" class="img-fluid">
        </div>
    </div>

    <div class="auth-right-form">
        <div class="auth-card">
            <div class="auth-header text-center mb-5">
                <div class="bg-gov-light-blue text-gov-blue d-inline-flex justify-content-center align-items-center rounded-circle mb-3" style="width:60px; height:60px;">
                    <i class="bi bi-key-fill fs-3"></i>
                </div>
                <h3 class="fw-bold">Password Recovery</h3>
                <p class="text-muted small">Enter your email address and we will securely email you a reset link.</p>
            </div>

            @if (ViewBag.ErrorMessage != null)
            {
                <div class="alert alert-danger border-0 small py-2 mb-4" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i> @ViewBag.ErrorMessage
                </div>
            }

            <form asp-action="ForgotPassword" method="post">
                <div class="auth-input-group mb-4">
                    <label class="auth-label">Registered Email Address</label>
                    <input type="email" name="email" class="auth-input" placeholder="e.g. yourname@company.com" required />
                </div>
                
                <button type="submit" class="auth-btn-primary mb-4">
                    Send Secure Reset Link <i class="bi bi-envelope-check ms-2"></i>
                </button>

                <div class="text-center mt-5 pt-3 border-top">
                    <a asp-action="Login" class="text-muted text-decoration-none d-flex align-items-center justify-content-center small fw-bold hover-primary mb-3">
                        <i class="bi bi-arrow-left me-2"></i> Back to login
                    </a>
                    <a href="/" class="text-muted text-decoration-none d-flex align-items-center justify-content-center small">
                        <i class="bi bi-house-door me-2"></i> Back to home
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

</body>
</html>
