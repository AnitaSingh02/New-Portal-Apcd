@model APCD.Web.Models.ApplicationUser
@{
    ViewData["Title"] = "OEM Registration";
    Layout = null; // No layout for full-screen auth page
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - APCD Portal</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

<div class="auth-split-wrapper">
    <!-- Left Branding Section -->
    <div class="auth-left-brand d-none d-lg-flex">
        <div class="auth-logo-container text-center">
                <img src="~/images/apcd-logo.png" alt="APCDES Logo" class="img-fluid">
        </div>
    </div>

    <!-- Right Form Section -->
    <div class="auth-right-form">
        <div class="auth-card">
            <div class="auth-header text-center">
                <h2 class="fw-bold">OEM Registration</h2>
                <p class="text-muted small">Register as an Air Pollution Control Device manufacturer to start your empanelment application</p>
            </div>

            <div class="auth-tab-group mb-4">
                <a asp-action="Login" class="auth-tab">Login</a>
                <a href="#" class="auth-tab active">OEM Register</a>
            </div>

            @if (ViewBag.ErrorMessage != null)
            {
                <div class="alert alert-danger border-0 small py-2 mb-4" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i> @ViewBag.ErrorMessage
                </div>
            }

            <form asp-action="Register" method="post" id="registerForm">
                <input type="hidden" asp-for="FullName" id="hiddenFullName" />
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="auth-label">First Name</label>
                        <div class="auth-input-group">
                            <input type="text" id="firstName" class="auth-input" placeholder="User Name" required oninput="updateFullName()" />
                        </div>
                    </div>
                    <div class="col-md-6">
                        <label class="auth-label">Last Name</label>
                        <div class="auth-input-group">
                            <input type="text" id="lastName" class="auth-input" placeholder="User Last Name" required oninput="updateFullName()" />
                        </div>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Email" class="auth-label">Email Address</label>
                        <div class="auth-input-group">
                            <input asp-for="Email" class="auth-input" placeholder="example@gmail.com" required />
                        </div>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="MobileNumber" class="auth-label">Mobile Number</label>
                        <div class="auth-input-group">
                            <input asp-for="MobileNumber" class="auth-input" placeholder="+919859698545" required />
                        </div>
                    </div>
                    <div class="col-md-6">
                        <label class="auth-label">Password</label>
                        <div class="auth-input-group">
                            <input type="password" name="password" id="password" class="auth-input" placeholder="@@#*%" required />
                            <i class="bi bi-eye password-toggle" onclick="togglePassword('password')"></i>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <label class="auth-label">Confirm Password</label>
                        <div class="auth-input-group">
                            <input type="password" id="confirmPassword" class="auth-input" placeholder="@@#*%" required />
                            <i class="bi bi-eye password-toggle" onclick="togglePassword('confirmPassword')"></i>
                        </div>
                    </div>
                </div>

                <p class="extra-small text-muted mt-2 mb-4" style="font-size: 0.75rem;">
                    Must contain: 8+ chars, uppercase, lowercase, number, special char (!@@#$%^&*)
                </p>

                <button type="submit" class="auth-btn-primary">
                    Create account & Start Application
                </button>

                <p class="text-center mt-4 small text-muted">
                    By registering, you agree to our <a href="#" class="text-decoration-none">Terms of Service</a> and <a href="#" class="text-decoration-none">Privacy Policy</a>
                </p>

                <div class="text-center mt-4">
                    <a href="/" class="text-muted text-decoration-none d-flex align-items-center justify-content-center small">
                        <i class="bi bi-arrow-left me-2"></i> Back to home
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    function updateFullName() {
        const firstName = document.getElementById('firstName').value.trim();
        const lastName = document.getElementById('lastName').value.trim();
        document.getElementById('hiddenFullName').value = `${firstName} ${lastName}`.trim();
    }

    function togglePassword(id) {
        const input = document.getElementById(id);
        const icon = event.target;
        if (input.type === "password") {
            input.type = "text";
            icon.classList.replace("bi-eye", "bi-eye-slash");
        } else {
            input.type = "password";
            icon.classList.replace("bi-eye-slash", "bi-eye");
        }
    }
</script>

</body>
</html>
