@model APCD.Web.Models.ApplicationUser
@{
    ViewData["Title"] = "Register";
}

<div class="container py-5 mt-5 animate-fade-in">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
                <div class="card-header bg-gov-blue text-white text-center py-5 border-0">
                    <div class="mb-3">
                        <i class="bi bi-briefcase-fill fs-1"></i>
                    </div>
                    <h3 class="fw-bold mb-0">OEM Registration</h3>
                    <p class="mb-0 opacity-75">Register your company to the APCD Empanelment Portal</p>
                </div>
                <div class="card-body p-5 bg-white">
                    @if (ViewBag.ErrorMessage != null)
                    {
                        <div class="alert alert-danger border-0 shadow-sm small py-2 mb-4" role="alert">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i> @ViewBag.ErrorMessage
                        </div>
                    }
                    
                    <form asp-action="Register" method="post">
                        <div class="row g-4">
                            <div class="col-md-12">
                                <label asp-for="FullName" class="form-label small fw-bold text-muted text-uppercase">Full Name / Primary Contact</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0"><i class="bi bi-person text-muted"></i></span>
                                    <input asp-for="FullName" class="form-control border-start-0 bg-light" placeholder="e.g. John Doe" required />
                                </div>
                                <span asp-validation-for="FullName" class="text-danger extra-small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Email" class="form-label small fw-bold text-muted text-uppercase">Official Email address</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0"><i class="bi bi-envelope text-muted"></i></span>
                                    <input asp-for="Email" class="form-control border-start-0 bg-light" placeholder="j.doe@company.com" required />
                                </div>
                                <span asp-validation-for="Email" class="text-danger extra-small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="MobileNumber" class="form-label small fw-bold text-muted text-uppercase">Mobile Number</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0"><i class="bi bi-phone text-muted"></i></span>
                                    <input asp-for="MobileNumber" class="form-control border-start-0 bg-light" placeholder="98XXXXXXXX" required />
                                </div>
                                <span asp-validation-for="MobileNumber" class="text-danger extra-small"></span>
                            </div>

                            <div class="col-md-12">
                                <label for="inputPassword" class="form-label small fw-bold text-muted text-uppercase">Create Password</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0"><i class="bi bi-key text-muted"></i></span>
                                    <input type="password" name="password" class="form-control border-start-0 bg-light" id="inputPassword" placeholder="Minimum 6 characters" required />
                                </div>
                            </div>
                        </div>

                        <div class="mt-5 d-grid gap-2">
                            <button type="submit" class="btn btn-gov-primary btn-lg shadow-sm rounded-pill fw-bold py-3">
                                Create Account & Continue <i class="bi bi-arrow-right-short ms-1"></i>
                            </button>
                        </div>

                        <p class="mt-4 text-center small text-muted px-lg-5">
                            By registering, you agree to the <a href="#">Terms of Use</a> and <a href="#">Privacy Policy</a> of NP-CPCB.
                        </p>
                    </form>
                </div>
                <div class="card-footer text-center py-4 bg-light border-0">
                    <p class="small text-muted mb-0">
                        Already have an account? <a asp-action="Login" class="fw-bold text-decoration-none text-gov-blue">Login Now</a>
                    </p>
                </div>
            </div>

            <div class="text-center mt-4 small mb-5">
                <a href="/" class="text-muted text-decoration-none">← Back to Homepage</a>
            </div>
        </div>
    </div>
</div>

<style>
    body { background-color: #f0f4f8; }
    .card-header { 
        position: relative; 
        background: linear-gradient(45deg, var(--gov-blue), var(--gov-accent)) !important;
    }
    .extra-small { font-size: 0.7rem; }
    .fw-600 { font-weight: 600; }
</style>
