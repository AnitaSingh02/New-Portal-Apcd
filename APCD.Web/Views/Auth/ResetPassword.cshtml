@{
    ViewData["Title"] = "Set New Password";
    Layout = null; 
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - APCD Portal</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

<div class="auth-split-wrapper">
    <div class="auth-left-brand d-none d-lg-flex">
        <div class="auth-logo-container text-center">
            <img src="~/images/apcd-logo.png" alt="APCDES Logo" class="img-fluid">
        </div>
    </div>

    <div class="auth-right-form">
        <div class="auth-card">
            <div class="auth-header text-center mb-5">
                <div class="bg-gov-light-blue text-gov-blue d-inline-flex justify-content-center align-items-center rounded-circle mb-3" style="width:60px; height:60px;">
                    <i class="bi bi-shield-lock-fill fs-3"></i>
                </div>
                <h3 class="fw-bold">Create New Password</h3>
                <p class="text-muted small">Please choose a strong, secure password for your account.</p>
            </div>

            @if (ViewBag.ErrorMessage != null)
            {
                <div class="alert alert-danger border-0 small py-2 mb-4" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i> @ViewBag.ErrorMessage
                </div>
            }

            <form asp-action="ResetPassword" method="post">
                <!-- Secret Payload -->
                <input type="hidden" name="token" value="@ViewBag.Token" />
                <input type="hidden" name="email" value="@ViewBag.Email" />

                <div class="auth-input-group mb-4">
                    <label class="auth-label">New Secure Password</label>
                    <div class="position-relative">
                        <input type="password" name="newPassword" id="newPassword" class="auth-input" placeholder="Create new password" required />
                    </div>
                </div>

                <div class="auth-input-group mb-5">
                    <label class="auth-label">Confirm New Password</label>
                    <div class="position-relative">
                        <input type="password" name="confirmPassword" id="confirmPassword" class="auth-input" placeholder="Verify new password" required />
                    </div>
                </div>
                
                <button type="submit" class="auth-btn-primary mb-4 p-3">
                    Update Password & Secure Account
                </button>
            </form>
        </div>
    </div>
</div>

</body>
</html>
