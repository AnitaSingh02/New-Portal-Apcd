@{
    ViewData["Title"] = "Password Reset Success";
    Layout = null; 
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - APCD Portal</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="bg-light">

<div class="d-flex justify-content-center align-items-center min-vh-100">
    <div class="card border-0 shadow-lg" style="max-width: 500px; border-radius: 20px;">
        <div class="card-body p-5 text-center">
            
            <div class="mb-4 text-white bg-success d-inline-flex align-items-center justify-content-center rounded-circle shadow-sm" style="width: 80px; height: 80px;">
                <i class="bi bi-shield-check" style="font-size: 3rem;"></i>
            </div>
            
            <h3 class="fw-bold text-dark mb-3">Password Updated</h3>
            <p class="text-muted mb-5">
                Your APCD OEM Empanelment Portal password has been reliably and securely updated! You can now resume your standard workflow logging deeply back into your dashboard.
            </p>

            <a asp-action="Login" class="btn btn-gov-primary px-5 py-3 rounded-pill w-100 fw-bold shadow-sm">
                Login with New Password <i class="bi bi-box-arrow-in-right ms-2"></i>
            </a>
        </div>
    </div>
</div>

</body>
</html>
