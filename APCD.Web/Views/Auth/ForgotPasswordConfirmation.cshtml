@{
    ViewData["Title"] = "Email Sent";
    Layout = null; 
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - APCD Portal</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="bg-light">

<div class="d-flex justify-content-center align-items-center min-vh-100">
    <div class="card border-0 shadow-lg" style="max-width: 500px; border-radius: 20px;">
        <div class="card-body p-5 text-center">
            <div class="mb-4 text-success d-inline-flex align-items-center justify-content-center bg-success-subtle rounded-circle" style="width: 80px; height: 80px;">
                <i class="bi bi-envelope-check-fill" style="font-size: 2.5rem;"></i>
            </div>
            
            <h3 class="fw-bold text-dark mb-3">Check Your Inbox</h3>
            <p class="text-muted mb-4">
                If the email address you entered is registered with us, you will receive a secure password reset link shortly. Please verify your spam/junk folder as well.
            </p>
            
            <div class="alert alert-warning small text-start border-0 rounded-3 mb-5" role="alert">
                <i class="bi bi-info-circle-fill me-1"></i> The secure token contained in the email will automatically expire defensively after exactly <strong>1 Hour</strong>.
            </div>

            <a asp-action="Login" class="btn btn-gov-primary px-5 py-2 rounded-pill w-100 fw-bold shadow-sm mb-3">
                Return to Login Page
            </a>
            <div>
                <a href="/" class="text-muted text-decoration-none small">
                    <i class="bi bi-house-door me-2"></i> Back to home
                </a>
            </div>
        </div>
    </div>
</div>

</body>
</html>
