@{
    ViewData["Title"] = "Logged Out";
}

<div class="container py-5 mt-5 animate-fade-in text-center">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
                <div class="card-body p-5">
                    <div class="mb-4">
                        <div class="bg-success-subtle d-inline-flex align-items-center justify-content-center rounded-circle shadow-sm" style="width: 100px; height: 100px;">
                            <i class="bi bi-shield-check text-success" style="font-size: 3.5rem;"></i>
                        </div>
                    </div>
                    <h2 class="fw-bold text-gov-blue mb-3">Successfully Logged Out</h2>
                    <p class="text-muted mb-5">You have been securely signed out of the APCD Empanelment Portal. We recommend closing this browser tab for your security.</p>
                    
                    <div class="d-grid gap-2">
                        <a href="/Auth/Login" class="btn btn-gov-primary btn-lg shadow-sm rounded-pill fw-bold">Sign In Again</a>
                        <a href="/" class="btn btn-link text-muted extra-small mt-2">Back to NPC Home</a>
                    </div>
                </div>
                <div class="card-footer bg-light py-3 border-0 small text-muted">
                    © 2026 National Productivity Council | Secure Session Ended
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    body { background-color: #f8f9fa; }
</style>
