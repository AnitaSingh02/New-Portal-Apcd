<!-- Fee Structure -->
<section id="fees" class="pricing-section py-5">
    <div class="container">

        <div class="section-head text-center mb-5">
            <span class="section-tag">Pricing</span>
            <h2 class="fw-bold">Empanelment Fee Structure</h2>
            <p class="text-muted">Transparent fee structure for OEM empanelment and certification</p>
        </div>

        <div class="row g-4 justify-content-center">

            <!-- Application Fee -->
            <div class="col-lg-3 col-md-6">
                <div class="fee-card text-center">
                    <div class="fee-icon">
                        <i class="bi bi-file-earmark-text"></i>
                    </div>

                    <h6 class="fee-title">Application Fee</h6>

                    <h2 class="fee-price">₹25,000</h2>

                    <p class="small fee-note">+18% GST Extra<br>Non-Refundable</p>

                    <ul class="fee-list">
                        <li><i class="bi bi-check-circle-fill text-success"></i> Company Registration</li>
                    </ul>
                </div>
            </div>

            <!-- Empanelment Fee (Highlighted) -->
            <div class="col-lg-3 col-md-6">
                <div class="fee-card highlight text-center">


                    <div class="fee-icon">
                        <i class="bi bi-award"></i>
                    </div>

                    <h6 class="fee-title">Empanelment Fee</h6>

                    <h2 class="fee-price">₹65,000</h2>
                    <p class="small fee-note">+18% GST Extra<br>Non-Refundable</p>

                    <p class="text-muted small">Per APCD Technology Type</p>

                    <ul class="fee-list">
                        <li><i class="bi bi-check-circle-fill text-success"></i> Provisional Technology Approval</li>
                    </ul>

                </div>
            </div>

            <!-- Field Verification -->
            <div class="col-lg-3 col-md-6">
                <div class="fee-card text-center">

                    <div class="fee-icon">
                        <i class="bi bi-search"></i>
                    </div>

