@{
    ViewData["Title"] = "Home Page";
}

<style>
    .hero-section {
        background: linear-gradient(135deg, var(--gov-blue) 0%, #004d99 100%);
        color: white;
        padding: 100px 0;
        position: relative;
        overflow: hidden;
    }

    .hero-section::after {
        content: "";
        position: absolute;
        top: 0;
        right: 0;
        bottom: 0;
        left: 0;
        background: url('https://www.transparenttextures.com/patterns/cubes.png');
        opacity: 0.1;
    }

    .feature-card {
        transition: transform 0.3s;
        border: none;
        border-radius: 15px;
    }

    .feature-card:hover {
        transform: translateY(-10px);
    }

    .step-number {
        width: 40px;
        height: 40px;
        background-color: var(--gov-blue);
        color: white;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        margin-bottom: 15px;
    }

    .section-title {
        color: var(--gov-blue);
        font-weight: 700;
        margin-bottom: 40px;
        position: relative;
        padding-bottom: 15px;
    }

    .section-title::after {
        content: "";
        position: absolute;
        bottom: 0;
        left: 50%;
        transform: translateX(-50%);
        width: 60px;
        height: 3px;
        background-color: var(--gov-gold);
    }
</style>

<section class="hero-section">
    <div class="container position-relative" style="z-index: 1;">
        <div class="row align-items-center">
            <div class="col-lg-7">
                <h1 class="display-4 fw-bold mb-4">Air Pollution Control Device Manufacturers Empanelment</h1>
                <p class="lead mb-5">Get your company empaneled as an approved manufacturer of APCDs under the Central Pollution Control Board (CPCB) guidelines. A seamless, 100% online process.</p>
                <div class="d-flex gap-3">
                    <a asp-controller="Auth" asp-action="Register" class="btn btn-warning btn-lg px-5 fw-bold">Start Application</a>
                    <a href="#process" class="btn btn-outline-light btn-lg px-5">View Process</a>
                </div>
                <div class="mt-5 d-flex gap-4">
                    <div>
                        <h3 class="fw-bold mb-0">500+</h3>
                        <p class="small text-light">Approved OEMs</p>
                    </div>
                    <div>
                        <h3 class="fw-bold mb-0">7-10</h3>
                        <p class="small text-light">Days Approval</p>
                    </div>
                    <div>
                        <h3 class="fw-bold mb-0">100%</h3>
                        <p class="small text-light">Online Process</p>
                    </div>
                </div>
            </div>
            <div class="col-lg-5 d-none d-lg-block text-center">
                <div class="bg-white bg-opacity-10 p-5 rounded-circle d-inline-block border border-white border-opacity-25">
                    <div class="bg-white bg-opacity-20 p-5 rounded-circle border border-white border-opacity-50">
                        <img src="https://img.icons8.com/color/144/null/verified-account.png" alt="Verified" />
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-5 bg-white">
    <div class="container">
        <div class="row text-center mb-5">
            <div class="col-12">
                <h2 class="section-title">Why Choose Our Portal?</h2>
                <p class="text-muted">Modern, efficient, and transparent empanelment process</p>
            </div>
        </div>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="card h-100 feature-card shadow-sm p-4">
                    <div class="mb-3 text-primary">
                        <img src="https://img.icons8.com/fluency/48/null/fast-forward.png" />
                    </div>
                    <h4>Fast Approval</h4>
                    <p class="text-muted small">Streamlined evaluation process leading to quick empanelment decisions.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 feature-card shadow-sm p-4">
                    <div class="mb-3 text-success">
                        <img src="https://img.icons8.com/fluency/48/null/checked-identification-documents.png" />
                    </div>
                    <h4>Secure & Transparent</h4>
                    <p class="text-muted small">Complete audit trail of your application with real-time status tracking.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 feature-card shadow-sm p-4">
                    <div class="mb-3 text-warning">
                        <img src="https://img.icons8.com/fluency/48/null/diploma.png" />
                    </div>
                    <h4>Digital Certificates</h4>
                    <p class="text-muted small">Instant digital certificate issuance upon successful empanelment.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<section id="process" class="py-5 bg-light">
    <div class="container">
        <div class="row text-center mb-5">
            <div class="col-12">
                <h2 class="section-title">Empanelment Process</h2>
                <p class="text-muted">Simple 7-step journey to get empaneled</p>
            </div>
        </div>
        <div class="row row-cols-1 row-cols-md-4 g-4 text-center">
            <div class="col">
                <div class="step-number mx-auto">1</div>
                <h5>Register OEM</h5>
                <p class="small text-muted">Create account with basic company details</p>
            </div>
            <div class="col">
                <div class="step-number mx-auto">2</div>
                <h5>Complete Form</h5>
                <p class="small text-muted">Fill info and upload required documents</p>
            </div>
            <div class="col">
                <div class="step-number mx-auto">3</div>
                <h5>Document Check</h5>
                <p class="small text-muted">Verification by NPC officers</p>
            </div>
            <div class="col">
                <div class="step-number mx-auto">4</div>
                <h5>Provisional Grant</h5>
                <p class="small text-muted">Granting provisional empanelment status</p>
            </div>
            <div class="col">
                <div class="step-number mx-auto">5</div>
                <h5>Field Visit</h5>
                <p class="small text-muted">Verification of installations and factory</p>
            </div>
            <div class="col">
                <div class="step-number mx-auto">6</div>
                <h5>Committee Review</h5>
                <p class="small text-muted">Review by expert committee members</p>
            </div>
            <div class="col">
                <div class="step-number mx-auto">7</div>
                <h5>Empanelment</h5>
                <p class="small text-muted">Final empanelment awarded (2 years)</p>
            </div>
        </div>
    </div>
</section>

<section id="fees" class="py-5 bg-white">
    <div class="container">
        <div class="row text-center mb-5">
            <div class="col-12">
                <h2 class="section-title">Fee Structure</h2>
                <p class="text-muted">Transparent pricing for the empanelment services</p>
            </div>
        </div>
        <div class="row g-4">
            <div class="col-md-3">
                <div class="card h-100 border-0 shadow-sm text-center">
                    <div class="card-body p-4">
                        <h6 class="text-uppercase text-muted mb-3">Application Fee</h6>
                        <h2 class="fw-bold text-primary">₹25,000</h2>
                        <p class="small">+ 18% GST</p>
                        <hr />
                        <ul class="list-unstyled text-start small mb-4">
                            <li><i class="bi bi-check2 text-success"></i> Portal Registration</li>
                            <li><i class="bi bi-check2 text-success"></i> Profile Setup</li>
                            <li><i class="bi bi-check2 text-success"></i> Basic Verification</li>
                        </ul>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card h-100 border-primary shadow text-center border-2">
                    <div class="card-body p-4">
                        <div class="badge bg-primary mb-3">Popular</div>
                        <h6 class="text-uppercase text-muted mb-3">Product Fee</h6>
                        <h2 class="fw-bold text-primary">₹65,000</h2>
                        <p class="small">Per APCD Type</p>
                        <hr />
                        <ul class="list-unstyled text-start small mb-4">
                            <li><i class="bi bi-check2 text-success"></i> Technical Evaluation</li>
                            <li><i class="bi bi-check2 text-success"></i> Model Verification</li>
                            <li><i class="bi bi-check2 text-success"></i> Digital Certificate</li>
                        </ul>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card h-100 border-0 shadow-sm text-center">
                    <div class="card-body p-4">
                        <h6 class="text-uppercase text-muted mb-3">Field Verification</h6>
                        <h2 class="fw-bold text-primary">₹57,000</h2>
                        <p class="small">Per Visit</p>
                        <hr />
                        <ul class="list-unstyled text-start small mb-4">
                            <li><i class="bi bi-check2 text-success"></i> On-site Inspection</li>
                            <li><i class="bi bi-check2 text-success"></i> Installation Check</li>
                            <li><i class="bi bi-check2 text-success"></i> Data Validation</li>
                        </ul>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card h-100 border-0 shadow-sm text-center">
                    <div class="card-body p-4">
                        <h6 class="text-uppercase text-muted mb-3">Renewal Fee</h6>
                        <h2 class="fw-bold text-primary">₹35,000</h2>
                        <p class="small">Per Year</p>
                        <hr />
                        <ul class="list-unstyled text-start small mb-4">
                            <li><i class="bi bi-check2 text-success"></i> Validity Extension</li>
                            <li><i class="bi bi-check2 text-success"></i> Yearly Compliance</li>
                            <li><i class="bi bi-check2 text-success"></i> Status Maintenance</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
        <div class="mt-5 p-4 bg-light rounded text-center small text-muted">
            Example: For 3 product categories, total fee = ₹25,000 + (3 × ₹65,000) + GST (18%) = ₹2,59,600
        </div>
    </div>
</section>

<section class="py-5 bg-primary text-white text-center">
    <div class="container">
        <h2 class="mb-4">Ready to Get Started?</h2>
        <p class="lead mb-4">Register your company today and begin your empanelment journey.</p>
        <a asp-controller="Auth" asp-action="Register" class="btn btn-light btn-lg px-5 text-primary fw-bold shadow-sm">Register Now</a>
    </div>
</section>
