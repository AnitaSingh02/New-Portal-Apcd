@{
    ViewData["Title"] = "Home Page";
}

<!-- Hero Section -->
<section class="hero-wrapper">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6 mb-5 mb-lg-0">
                <span class="section-tag">Empanelment Portal</span>
                <h1 class="display-3 mb-4">Certification Council Bureau for <span class="text-primary">Air Pollution Control</span> Equipment</h1>
                <p class="lead text-muted mb-5">Streamline your OEM empanelment process with NPC. A transparent, 100% digital platform for technical evaluation and certification of APCD manufacturers.</p>
                <div class="d-flex gap-3">
                    <a asp-controller="Auth" asp-action="Register" class="btn btn-primary-custom btn-lg px-5">Get Started Now</a>
                    <a href="#process" class="btn btn-outline-primary btn-lg px-5">Watch Video</a>
                </div>
                <div class="row mt-5 pt-4">
                    <div class="col-4">
                        <h4 class="mb-0">2.1k+</h4>
                        <p class="small text-muted">User Reviews</p>
                    </div>
                    <div class="col-4 border-start">
                        <h4 class="mb-0">6.1k+</h4>
                        <p class="small text-muted">Total Projects</p>
                    </div>
                    <div class="col-4 border-start">
                        <h4 class="mb-0">850k+</h4>
                        <p class="small text-muted">Happy Users</p>
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="hero-img-container ps-lg-5">
                    <img src="~/images/hero.png" alt="Industrial Plant" class="img-fluid">
                    <div class="hero-stat-card d-none d-md-block">
                        <div class="d-flex align-items-center gap-3">
                            <div class="bg-light-blue p-2 rounded">
                                <i class="bi bi-patch-check-fill text-success fs-3"></i>
                            </div>
                            <div>
                                <h6 class="mb-0">Approved OEM</h6>
                                <p class="small text-muted mb-0">Verified by NPC Experts</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Our Objectives -->
<section class="py-5 my-5">
    <div class="container">
        <div class="section-head text-center">
            <span class="section-tag">Our Vision</span>
            <h2>Our Core Objectives</h2>
            <p class="text-muted mx-auto" style="max-width: 600px;">The goal is to reduce pollution and ensure that industrial units install high-quality, verified air pollution control devices.</p>
        </div>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="obj-card blue shadow h-100">
                    <i class="bi bi-search fs-1 mb-4 d-block"></i>
                    <h3>APCD Inspection</h3>
                    <p class="opacity-75">Rigorous on-site inspection of manufacturing facilities and trial installations to ensure quality standards.</p>
                    <a href="#" class="text-white fw-bold text-decoration-none">Learn More <i class="bi bi-arrow-right"></i></a>
                </div>
            </div>
            <div class="col-md-4">
                <div class="obj-card cyan shadow h-100">
                    <i class="bi bi-shield-check fs-1 mb-4 d-block"></i>
                    <h3>Empanelment of OEM</h3>
                    <p class="opacity-75">Comprehensive verification of Original Equipment Manufacturers for long-term empanelment with NPC/CPCB.</p>
                    <a href="#" class="text-white fw-bold text-decoration-none">Learn More <i class="bi bi-arrow-right"></i></a>
                </div>
            </div>
            <div class="col-md-4">
                <div class="obj-card teal shadow h-100">
                    <i class="bi bi-gear-wide-connected fs-1 mb-4 d-block"></i>
                    <h3>Technical Evaluation</h3>
                    <p class="opacity-75">Scientific evaluation of APCD performance by expert committees to validate pollution reduction efficiency.</p>
                    <a href="#" class="text-white fw-bold text-decoration-none">Learn More <i class="bi bi-arrow-right"></i></a>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Process Timeline -->
<section id="process" class="py-5 bg-light">
    <div class="container">
        <div class="section-head text-center">
            <span class="section-tag">Step-by-Step</span>
            <h2>Empanelment Journey</h2>
        </div>
        <div class="timeline-container">
            <div class="timeline-line d-none d-md-block"></div>
            
            <div class="timeline-item">
                <div class="timeline-dot"></div>
                <div class="timeline-content">
                    <span class="badge bg-primary mb-2">Step 01</span>
                    <h4>OEM Registration</h4>
                    <p class="small text-muted mb-0">Create your account with basic company profile and contact information to start the journey.</p>
                </div>
            </div>
            
            <div class="timeline-item">
                <div class="timeline-dot"></div>
                <div class="timeline-content">
                    <span class="badge bg-primary mb-2">Step 02</span>
                    <h4>Application Submission</h4>
                    <p class="small text-muted mb-0">Upload technical specifications, manufacturing capacity, and previous installation reports.</p>
                </div>
            </div>

            <div class="timeline-item">
                <div class="timeline-dot"></div>
                <div class="timeline-content">
                    <span class="badge bg-primary mb-2">Step 03</span>
                    <h4>Document Verification</h4>
                    <p class="small text-muted mb-0">NPC officers will review your documents for compliance with regulatory standards and guidelines.</p>
                </div>
            </div>

            <div class="timeline-item">
                <div class="timeline-dot"></div>
                <div class="timeline-content">
                    <span class="badge bg-primary mb-2">Step 04</span>
                    <h4>Field Inspection</h4>
                    <p class="small text-muted mb-0">Physical verification of manufacturing units and verification of installations at client sites.</p>
                </div>
            </div>

            <div class="timeline-item">
                <div class="timeline-dot"></div>
                <div class="timeline-content">
                    <span class="badge bg-primary mb-2">Step 05</span>
                    <h4>Technical Review</h4>
                    <p class="small text-muted mb-0">Review by expert committee members to evaluate technical performance of APCD models.</p>
                </div>
            </div>

            <div class="timeline-item">
                <div class="timeline-dot"></div>
                <div class="timeline-content">
                    <span class="badge bg-primary mb-2">Step 06</span>
                    <h4>Final Certification</h4>
                    <p class="small text-muted mb-0">Issuance of digital empanelment certificate valid for a period of two years.</p>
                </div>
            </div>
        </div>
        <div class="text-center mt-5">
            <button class="btn btn-primary-custom">Download Empanelment Guidelines <i class="bi bi-file-earmark-pdf ms-2"></i></button>
        </div>
    </div>
</section>

<!-- Our Categories -->
<section class="py-5 my-5">
    <div class="container">
        <div class="section-head text-center">
            <span class="section-tag">Our Expertise</span>
            <h2>APCD Categories We Support</h2>
        </div>
        <div class="row g-4">
            <div class="col-md">
                <div class="cat-card">
                    <i class="bi bi-filter-circle cat-icon"></i>
                    <h5>Bag Filter</h5>
                    <p class="small text-muted">Efficient particulate matter removal system.</p>
                </div>
            </div>
            <div class="col-md">
                <div class="cat-card">
                    <i class="bi bi-wind cat-icon"></i>
                    <h5>Cyclones</h5>
                    <p class="small text-muted">Centrifugal separation for larger dust particles.</p>
                </div>
            </div>
            <div class="col-md">
                <div class="cat-card">
                    <i class="bi bi-lightning-charge cat-icon"></i>
                    <h5>ESP</h5>
                    <p class="small text-muted">Electrostatic precipitators for fine particles.</p>
                </div>
            </div>
            <div class="col-md">
                <div class="cat-card">
                    <i class="bi bi-droplet cat-icon"></i>
                    <h5>Scrubbers</h5>
                    <p class="small text-muted">Wet removal systems for gases and particulates.</p>
                </div>
            </div>
            <div class="col-md">
                <div class="cat-card">
                    <i class="bi bi-box-seam cat-icon"></i>
                    <h5>Bio-Filters</h5>
                    <p class="small text-muted">Biological control of odor and toxic gases.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Working Group Categories -->
