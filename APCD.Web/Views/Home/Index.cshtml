@{
    ViewData["Title"] = "Home Page";
}

@section Styles {
    <link rel="stylesheet" href="~/css/apcd-categories.css" asp-append-version="true" />
}
<style>
    .hero-wrapper{
    background:#f4f7fb;
    padding:70px 0;
}

.hero-content{
    padding-left:6%;
    padding-right:4%;
}

.hero-title{
    font-size:2.2rem;
    line-height:1.45;
    font-weight:600;
    color:#0d3b66;
    max-width:650px;
}

.hero-img-container{
    position:relative;
    padding-right:4%;
}

.hero-img{
    width:100%;
    height:520px;
    object-fit:cover;
    border-radius:18px;
}

.hero-stat-card{
    position:absolute;
    bottom:25px;
    right:40px;
    background:#fff;
    padding:12px 18px;
    border-radius:10px;
    box-shadow:0 8px 20px rgba(0,0,0,0.08);
}

.btn-primary-custom{
    background:#0d3b66;
    border:none;
    padding:12px 28px;
    border-radius:8px;
}

.btn-primary-custom:hover{
    background:#092c4c;
}

    .display-4 {
        font-size: 38px;
    }

    .pricing-section {
        background: #f6f8fb;
    }

    .fee-card {
        background: white;
        border-radius: 14px;
        padding: 35px 25px;
        transition: all .3s ease;
        border: 1px solid #e6e6e6;
        height: 100%;
    }

        .fee-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 15px 35px rgba(0,0,0,0.08);
        }

    .fee-icon {
        font-size: 32px;
        color: #0d6efd;
        margin-bottom: 15px;
    }

    .fee-title {
        font-weight: 600;
        text-transform: uppercase;
        font-size: 13px;
        color: #6c757d;
    }

    .fee-price {
        font-size: 38px;
        font-weight: 700;
        color: #0d3b66;
        margin: 15px 0;
    }

    .fee-list {
        list-style: none;
        padding: 0;
        margin-top: 20px;
        text-align: left;
    }

        .fee-list li {
            margin-bottom: 8px;
            font-size: 14px;
        }

        .fee-list i {
            margin-right: 6px;
        }

    /* Highlight card */
    .highlight {
        border: 2px solid #0d6efd;
        transform: scale(1.03);
        box-shadow: 0 12px 35px rgba(13,110,253,0.15);
    }

    /* ============================= */
    /* PRICING SECTION */
    /* ============================= */
    .fee-note {
        color: #28a745; /* professional green */
        font-weight: 500;
    }
    .pricing-section {
        background: #f6f8fb;
    }

    /* Section Heading */

    .section-tag {
        color: #1e6bb8;
        font-weight: 600;
        letter-spacing: 1px;
        text-transform: uppercase;
        font-size: 14px;
    }

    .section-head h2 {
        color: #0d3b66;
        font-weight: 700;
    }

    .section-head p {
        color: #6c757d;
    }

    /* ============================= */
    /* FEE CARD */
    /* ============================= */

    .fee-card {
        background: #ffffff;
        border-radius: 14px;
        padding: 35px 25px;
        border: 1px solid #e6e6e6;
        transition: all .3s ease;
        height: 100%;
    }

        .fee-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 15px 35px rgba(0,0,0,0.08);
        }

    /* Highlight Card */

    .highlight {
        border: 2px solid #1e6bb8;
        box-shadow: 0 10px 30px rgba(30,107,184,0.15);
        transform: scale(1.03);
    }

    /* ============================= */
    /* ICON */
    /* ============================= */

    .fee-icon {
        margin-bottom: 15px;
    }

        .fee-icon i {
            font-size: 32px;
            color: #1e6bb8;
        }

    /* ============================= */
    /* TITLE */
    /* ============================= */

    .fee-title {
        color: #6c757d;
        font-weight: 600;
        text-transform: uppercase;
        font-size: 13px;
        letter-spacing: .5px;
        margin-bottom: 10px;
    }

    /* ============================= */
    /* PRICE */
    /* ============================= */

    .fee-price {
        color: #0d3b66;
        font-size: 40px;
        font-weight: 700;
        margin: 15px 0;
    }

    /* ============================= */
    /* DESCRIPTION */
    /* ============================= */
  

    /* ============================= */
    /* FEATURE LIST */
    /* ============================= */

    .fee-list {
        list-style: none;
        padding: 0;
        margin-top: 20px;
        text-align: left;
    }

        .fee-list li {
            margin-bottom: 10px;
            font-size: 14px;
            color: #495057;
        }

        .fee-list i {
            margin-right: 6px;
            color: #28a745;
        }

    /* ============================= */
    /* RESPONSIVE */
    /* ============================= */

    @@media (max-width:768px){
        .fee-price

    {
        font-size: 32px;
    }

    .highlight {
        transform: none;
    }
    }
    
</style>

<!-- Hero Section -->
<section class="hero-wrapper">
    <div class="container-fluid">
        <div class="row align-items-center">

            <!-- LEFT CONTENT -->
            <div class="col-lg-6 hero-content">
                <h1 class="hero-title">
                    Empanelment of Original Equipment Manufacturers (OEMs)
                    of Air Pollution Control Devices (APCDs) for
                    Installation / Upgradation in Industrial Units in Delhi – NCR
                </h1>

                <a asp-controller="Auth" asp-action="Register"
                   class="btn btn-primary-custom btn-lg mt-3">
                    Get Started Now
                </a>
            </div>

            <!-- RIGHT IMAGE -->
            <div class="col-lg-6 hero-img-container">
                <img src="~/images/hero.png" alt="Industrial Plant" class="hero-img">

                <div class="hero-stat-card">
                    <div class="d-flex align-items-center gap-2">
                        <i class="bi bi-patch-check-fill text-success fs-4"></i>
                        <div>
                            <strong>Approved OEM</strong><br>
                            <small class="text-muted">Verified by NPC Experts</small>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>
<!-- Our Objectives -->
<section class="py-5 my-5">
    <div class="container">
        <div class="section-head text-center">
            <span class="section-tag">Our Vision</span>
            <h2>Our Core Objectives</h2>
            <p class="text-muted mx-auto" style="max-width: 600px;">The goal is to reduce pollution and ensure that industrial units install high-quality, verified air pollution control devices.</p>
        </div>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="obj-card blue shadow h-100">
                    <i class="bi bi-search fs-1 mb-4 d-block"></i>
                    <h3>APCD Inspection</h3>
                    <p class="opacity-75">Rigorous on-site inspection of manufacturing facilities and trial installations to ensure quality standards.</p>
                    <a href="#" class="text-white fw-bold text-decoration-none">Learn More <i class="bi bi-arrow-right"></i></a>
                </div>
            </div>
            <div class="col-md-4">
                <div class="obj-card cyan shadow h-100">
                    <i class="bi bi-shield-check fs-1 mb-4 d-block"></i>
                    <h3>Empanelment of OEM</h3>
                    <p class="opacity-75">Comprehensive verification of Original Equipment Manufacturers for long-term empanelment with NPC/CPCB.</p>
                    <a href="#" class="text-white fw-bold text-decoration-none">Learn More <i class="bi bi-arrow-right"></i></a>
                </div>
            </div>
            <div class="col-md-4">
                <div class="obj-card teal shadow h-100">
                    <i class="bi bi-gear-wide-connected fs-1 mb-4 d-block"></i>
                    <h3>Technical Evaluation</h3>
                    <p class="opacity-75">Scientific evaluation of APCD performance by expert committees to validate pollution reduction efficiency.</p>
                    <a href="#" class="text-white fw-bold text-decoration-none">Learn More <i class="bi bi-arrow-right"></i></a>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Process Timeline -->
<section id="process" class="py-5 bg-light">
    <div class="container">
        <div class="section-head text-center">
            <span class="section-tag">Step-by-Step</span>
            <h2>Empanelment Journey</h2>
        </div>
        <div class="timeline-container">
            <div class="timeline-line d-none d-md-block"></div>
            
            <div class="timeline-item">
                <div class="timeline-dot"></div>
                <div class="timeline-content">
                    <span class="badge bg-primary mb-2">Step 01</span>
                    <h4>OEM Registration</h4>
                    <p class="small text-muted mb-0">Create your account with basic company profile and contact information to start the journey.</p>
                </div>
            </div>
            
            <div class="timeline-item">
                <div class="timeline-dot"></div>
                <div class="timeline-content">
                    <span class="badge bg-primary mb-2">Step 02</span>
                    <h4>Application Submission</h4>
                    <p class="small text-muted mb-0">Upload technical specifications, manufacturing capacity, and previous installation reports.</p>
                </div>
            </div>

            <div class="timeline-item">
                <div class="timeline-dot"></div>
                <div class="timeline-content">
                    <span class="badge bg-primary mb-2">Step 03</span>
                    <h4>Document Verification</h4>
                    <p class="small text-muted mb-0">NPC officers will review your documents for compliance with regulatory standards and guidelines.</p>
                </div>
            </div>

            <div class="timeline-item">
                <div class="timeline-dot"></div>
                <div class="timeline-content">
                    <span class="badge bg-primary mb-2">Step 04</span>
                    <h4>Field Inspection</h4>
                    <p class="small text-muted mb-0">Physical verification of manufacturing units and verification of installations at client sites.</p>
                </div>
            </div>

            <div class="timeline-item">
                <div class="timeline-dot"></div>
                <div class="timeline-content">
                    <span class="badge bg-primary mb-2">Step 05</span>
                    <h4>Technical Review</h4>
                    <p class="small text-muted mb-0">Review by expert committee members to evaluate technical performance of APCD models.</p>
                </div>
            </div>

            <div class="timeline-item">
                <div class="timeline-dot"></div>
                <div class="timeline-content">
                    <span class="badge bg-primary mb-2">Step 06</span>
                    <h4>Final Certification</h4>
                    <p class="small text-muted mb-0">Issuance of digital empanelment certificate valid for a period of two years.</p>
                </div>
            </div>
        </div>
        <div class="text-center mt-5">
            <button class="btn btn-primary-custom">Download Empanelment Guidelines <i class="bi bi-file-earmark-pdf ms-2"></i></button>
        </div>
    </div>
</section>

<!-- Types of APCD Based on Category Section -->
<section class="apcd-section">
    <div class="container">
        <div class="section-head text-center mb-5 animate-fade-up">
            <span class="section-tag">Industry Standards</span>
            <h2 class="display-5 fw-bold text-dark">Types of APCD Based on Category</h2>
            <div class="mx-auto bg-primary rounded-pill mb-4" style="width: 80px; height: 4px;"></div>
            <p class="text-muted mx-auto" style="max-width: 700px;">Explore the classification of Air Pollution Control Devices (APCD) based on their technical application and filtration mechanisms for industrial environmental protection.</p>
        </div>

        <div class="row g-4">
            <!-- 1. ESP -->
            <div class="col-lg-4 col-md-6">
                <div class="apcd-card animate-fade-up" style="animation-delay: 0.1s;">
                    <div class="apcd-icon-wrapper">
                        <i class="fa-solid fa-bolt-lightning"></i>
                    </div>
                    <h4 class="apcd-title">ESP</h4>
                    <p class="apcd-desc">Electrostatic precipitators for fine particulate control in high-volume industrial exhaust streams.</p>
                    
                    <button class="apcd-expand-btn collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#esp-subs">
                        View Sub-Types <i class="fa-solid fa-chevron-down ms-1"></i>
                    </button>
                    
                    <div class="collapse" id="esp-subs">
                        <ul class="subtype-list">
                            <li class="subtype-item"><i class="fa-solid fa-circle-check"></i> Dry ESP (Plate Type / Tube Type)</li>
                            <li class="subtype-item"><i class="fa-solid fa-circle-check"></i> Wet ESP</li>
                        </ul>
                    </div>
                </div>
            </div>

            <!-- 2. Bag Filter -->
            <div class="col-lg-4 col-md-6">
                <div class="apcd-card animate-fade-up" style="animation-delay: 0.2s;">
                    <div class="apcd-icon-wrapper">
                        <i class="fa-solid fa-filter"></i>
                    </div>
                    <h4 class="apcd-title">Bag Filter / Baghouse Systems</h4>
                    <p class="apcd-desc">Advanced fabric filtration systems designed for efficient industrial dust and particulate removal.</p>
                    
                    <button class="apcd-expand-btn collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#bag-subs">
                        View Sub-Types <i class="fa-solid fa-chevron-down ms-1"></i>
                    </button>
                    
                    <div class="collapse" id="bag-subs">
                        <ul class="subtype-list">
                            <li class="subtype-item"><i class="fa-solid fa-circle-check"></i> Pulse Jet Baghouse</li>
                            <li class="subtype-item"><i class="fa-solid fa-circle-check"></i> Reverse Air Baghouse</li>
                            <li class="subtype-item"><i class="fa-solid fa-circle-check"></i> Mechanical Shaker Baghouse</li>
                        </ul>
                    </div>
                </div>
            </div>

            <!-- 3. Cyclones -->
            <div class="col-lg-4 col-md-6">
                <div class="apcd-card animate-fade-up" style="animation-delay: 0.3s;">
                    <div class="apcd-icon-wrapper">
                        <i class="fa-solid fa-tornado"></i>
                    </div>
                    <h4 class="apcd-title">Cyclones</h4>
                    <p class="apcd-desc">Centrifugal separation technology optimized for higher-mass dust particles and pre-filtration.</p>
                    
                    <button class="apcd-expand-btn collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#cyclone-subs">
                        View Sub-Types <i class="fa-solid fa-chevron-down ms-1"></i>
                    </button>
                    
                    <div class="collapse" id="cyclone-subs">
                        <ul class="subtype-list">
                            <li class="subtype-item"><i class="fa-solid fa-circle-check"></i> Single Cyclone</li>
                            <li class="subtype-item"><i class="fa-solid fa-circle-check"></i> Twin Cyclone</li>
                            <li class="subtype-item"><i class="fa-solid fa-circle-check"></i> Multi Cyclone / Multi-Clone</li>
                            <li class="subtype-item"><i class="fa-solid fa-circle-check"></i> High-Efficiency Cyclone</li>
                        </ul>
                    </div>
                </div>
            </div>

            <!-- 4. Wet Scrubber -->
            <div class="col-lg-4 col-md-6">
                <div class="apcd-card animate-fade-up" style="animation-delay: 0.4s;">
                    <div class="apcd-icon-wrapper">
                        <i class="fa-solid fa-droplet"></i>
                    </div>
                    <h4 class="apcd-title">Wet Scrubber</h4>
                    <p class="apcd-desc">Specialized wet gas cleaning systems for capturing both gases and fine particulates with liquid media.</p>
                    
                    <button class="apcd-expand-btn collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#wet-subs">
                        View Sub-Types <i class="fa-solid fa-chevron-down ms-1"></i>
                    </button>
                    
                    <div class="collapse" id="wet-subs">
                        <ul class="subtype-list">
                            <li class="subtype-item"><i class="fa-solid fa-circle-check"></i> Venturi Scrubber</li>
                            <li class="subtype-item"><i class="fa-solid fa-circle-check"></i> Spray Tower / Spray Scrubber</li>
                            <li class="subtype-item"><i class="fa-solid fa-circle-check"></i> Packed Bed Scrubber</li>
                            <li class="subtype-item"><i class="fa-solid fa-circle-check"></i> Submerged Scrubber</li>
                            <li class="subtype-item"><i class="fa-solid fa-circle-check"></i> Multi-Stage Wet Scrubber</li>
                        </ul>
                    </div>
                </div>
            </div>

            <!-- 5. Dry Scrubber -->
            <div class="col-lg-4 col-md-6">
                <div class="apcd-card animate-fade-up" style="animation-delay: 0.5s;">
                    <div class="apcd-icon-wrapper">
                        <i class="fa-solid fa-wind"></i>
                    </div>
                    <h4 class="apcd-title">Dry Scrubber</h4>
                    <p class="apcd-desc">Advanced dry chemical injection systems for removing acid gases from combustion exhaust.</p>
                    
                    <button class="apcd-expand-btn collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#dry-subs">
                        View Sub-Types <i class="fa-solid fa-chevron-down ms-1"></i>
                    </button>
                    
                    <div class="collapse" id="dry-subs">
                        <ul class="subtype-list">
                            <li class="subtype-item"><i class="fa-solid fa-circle-check"></i> Dry Sorbent Injection</li>
                            <li class="subtype-item"><i class="fa-solid fa-circle-check"></i> Semi-Dry Scrubber</li>
                        </ul>
                    </div>
                </div>
            </div>

            <!-- 6. Hybrid -->
            <div class="col-lg-4 col-md-6">
                <div class="apcd-card animate-fade-up" style="animation-delay: 0.6s;">
                    <div class="apcd-icon-wrapper">
                        <i class="fa-solid fa-microchip"></i>
                    </div>
                    <h4 class="apcd-title">Hybrid / Other Technologies</h4>
                    <p class="apcd-desc">Innovative combinations or patented advanced technologies for high-efficiency pollution control.</p>
                    
                    <button class="apcd-expand-btn collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#hybrid-subs">
                        View Sub-Types <i class="fa-solid fa-chevron-down ms-1"></i>
                    </button>
                    
                    <div class="collapse" id="hybrid-subs">
                        <ul class="subtype-list">
                            <li class="subtype-item"><i class="fa-solid fa-circle-check"></i> Hybrid ESP–Baghouse</li>
                            <li class="subtype-item"><i class="fa-solid fa-circle-check"></i> Hybrid Wet–Dry Scrubbers</li>
                            <li class="subtype-item"><i class="fa-solid fa-circle-check"></i> Electrostatic Gravel Bed</li>
                            <li class="subtype-item"><i class="fa-solid fa-circle-check"></i> Advanced / Patented Technologies</li>
                        </ul>
                    </div>
                </div>
            </div>

            <!-- 7. Extraction Systems -->
            <div class="col-lg-4 col-md-6 mx-auto">
                <div class="apcd-card animate-fade-up" style="animation-delay: 0.7s;">
                    <div class="apcd-icon-wrapper">
                        <i class="fa-solid fa-fan"></i>
                    </div>
                    <h4 class="apcd-title">Fume / Dust Extraction</h4>
                    <p class="apcd-desc">Localized exhaust ventilation systems designed to capture industrial fumes and dust at the source.</p>
                    
                    <button class="apcd-expand-btn collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#extract-subs">
                        View Sub-Types <i class="fa-solid fa-chevron-down ms-1"></i>
                    </button>
                    
                    <div class="collapse" id="extract-subs">
                        <ul class="subtype-list">
                            <li class="subtype-item"><i class="fa-solid fa-circle-check"></i> Industrial Fume Extraction</li>
                            <li class="subtype-item"><i class="fa-solid fa-circle-check"></i> Dust Extraction Systems</li>
                            <li class="subtype-item"><i class="fa-solid fa-circle-check"></i> Exhaust Ventilation (LEV)</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

